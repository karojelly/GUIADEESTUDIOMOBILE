    {id:"1.3.4",tema:"Ecuaciones lineales con una incógnita",
     pregunta:"¿Cuál es la solución de 3x − 7 = 11?",
     opts:["x = 6","x = 4","x = 3"],c:0,
     exp:"3x = 11 + 7 = 18; x = 18/3 = <b>6</b>. Una ecuación lineal tiene la forma ax + b = c y se resuelve despejando la incógnita."},
    {id:"1.3.5",tema:"Ecuaciones cuadráticas con una incógnita",
     pregunta:"¿Cuáles son las soluciones de x² − 5x + 6 = 0?",
     opts:["x = 2 y x = 3","x = −2 y x = −3","x = 1 y x = 6"],c:0,
     exp:"Factorizando: (x−2)(x−3) = 0, por lo que <b>x = 2 o x = 3</b>. Las ecuaciones cuadráticas ax²+bx+c=0 pueden resolverse por factorización o fórmula general."},
    {id:"1.3.6",tema:"Sistemas de ecuaciones lineales con dos incógnitas",
     pregunta:"Si x + y = 10 y x − y = 4, ¿cuánto vale x?",
     opts:["7","6","3"],c:0,
     exp:"Sumando las ecuaciones: 2x = 14, entonces <b>x = 7</b>. Los sistemas de dos ecuaciones con dos incógnitas se resuelven por suma, sustitución o igualación."},
    {id:"1.3.7",tema:"Interés simple",
     pregunta:"Se invierte $5,000 a una tasa de interés simple del 8% anual durante 3 años. ¿Cuánto es el interés generado?",
     opts:["$1,200","$1,500","$4,000"],c:0,
     exp:"Interés simple: I = C × r × t = 5000 × 0.08 × 3 = <b>$1,200</b>. En el interés simple, los intereses se calculan siempre sobre el capital inicial."},
    {id:"1.3.8",tema:"Interés compuesto",
     pregunta:"¿Cuál es la característica principal del interés compuesto frente al interés simple?",
     opts:["Los intereses generados se suman al capital y generan nuevos intereses","La tasa de interés varía cada período","El capital se divide entre períodos"],c:0,
     exp:"En el <b>interés compuesto</b>, al final de cada período los intereses se capitalizan (se suman al capital), de modo que en el siguiente período se calculan intereses sobre un capital mayor."}
  ]},
  {id:"1.4",nombre:"Pensamiento aritmético",reactivos:5,temas:[
    {id:"1.4.1",tema:"Mínimo común múltiplo (MCM)",
     pregunta:"¿Cuál es el Mínimo Común Múltiplo de 4 y 6?",
     opts:["12","24","8"],c:0,
     exp:"Los múltiplos de 4: 4, 8, <b>12</b>, 16… Los de 6: 6, <b>12</b>, 18… El MCM es el menor múltiplo que ambos comparten: <b>12</b>."},
    {id:"1.4.2",tema:"Máximo común divisor (MCD)",
     pregunta:"¿Cuál es el Máximo Común Divisor de 18 y 24?",
     opts:["6","9","12"],c:0,
     exp:"Divisores de 18: 1,2,3,6,9,18. Divisores de 24: 1,2,3,4,6,8,12,24. El mayor divisor común a ambos es <b>6</b>."},
    {id:"1.4.3",tema:"Razones aritméticas o geométricas",
     pregunta:"En la secuencia 3, 6, 12, 24… ¿qué tipo de razón existe entre términos consecutivos?",
     opts:["Razón geométrica de factor 2","Razón aritmética de diferencia 3","Razón aritmética de diferencia 6"],c:0,
     exp:"Cada término se obtiene <b>multiplicando por 2</b> el anterior, lo que constituye una <b>razón geométrica</b> (progresión geométrica) con razón r = 2."},
    {id:"1.4.4",tema:"Proporcionalidad directa o inversa",
     pregunta:"Si 5 obreros tardan 12 días en terminar una obra, ¿cuántos días tardarán 10 obreros?",
     opts:["6 días","24 días","60 días"],c:0,
     exp:"Esta es una <b>proporcionalidad inversa</b>: al doble de obreros, la mitad de tiempo. 5×12 = 10×x; x = 60/10 = <b>6 días</b>."},
    {id:"1.4.5",tema:"Porcentajes",
     pregunta:"Un artículo cuesta $800. Si tiene un descuento del 15%, ¿cuál es el precio final?",
     opts:["$680","$700","$720"],c:0,
     exp:"Descuento = 800 × 0.15 = $120. Precio final = 800 − 120 = <b>$680</b>. Los porcentajes expresan una parte de cada 100."}
  ]},
  {id:"1.5",nombre:"Pensamiento geométrico",reactivos:4,temas:[
    {id:"1.5.1",tema:"Área de figuras geométricas simples",
     pregunta:"¿Cuál es el área de un triángulo con base 10 cm y altura 6 cm?",
     opts:["30 cm²","60 cm²","16 cm²"],c:0,
     exp:"Área del triángulo = (base × altura) / 2 = (10 × 6) / 2 = <b>30 cm²</b>."},
    {id:"1.5.2",tema:"Propiedades de los triángulos congruentes o semejantes",
     pregunta:"Dos triángulos son semejantes cuando:",
     opts:["Tienen los mismos ángulos y sus lados son proporcionales","Tienen los mismos ángulos y lados iguales","Tienen la misma área"],c:0,
     exp:"Los triángulos <b>semejantes</b> tienen los mismos ángulos (son congruentes) y sus lados correspondientes son proporcionales. Los triángulos <b>congruentes</b> tienen además iguales los lados."},
    {id:"1.5.3",tema:"Teorema de Pitágoras",
     pregunta:"En un triángulo rectángulo, los catetos miden 3 y 4 cm. ¿Cuánto mide la hipotenusa?",
     opts:["5 cm","7 cm","6 cm"],c:0,
     exp:"Teorema de Pitágoras: c² = a² + b² = 9 + 16 = 25; c = <b>5 cm</b>. La hipotenusa es el lado opuesto al ángulo recto."},
    {id:"1.5.4",tema:"Área de figuras en el plano cartesiano",
     pregunta:"Un rectángulo tiene vértices en (0,0), (4,0), (4,3) y (0,3) en el plano cartesiano. ¿Cuál es su área?",
     opts:["12 unidades²","14 unidades²","7 unidades²"],c:0,
     exp:"Base = 4 unidades, altura = 3 unidades. Área = base × altura = 4 × 3 = <b>12 unidades²</b>."}
  ]},
  {id:"1.6",nombre:"Pensamiento variacional",reactivos:6,temas:[
    {id:"1.6.1",tema:"Representación de intervalos mediante desigualdades",
     pregunta:"¿Qué desigualdad representa el intervalo (−∞, 5]?",
     opts:["x ≤ 5","x < 5","x ≥ 5"],c:0,
     exp:"El intervalo (−∞, 5] incluye todos los valores menores o iguales a 5, representado por <b>x ≤ 5</b>. El corchete ] indica que el 5 se incluye."},
    {id:"1.6.2",tema:"Gráficas de funciones de una variable real",
     pregunta:"¿Cuál es la gráfica de la función f(x) = x²?",
     opts:["Una parábola con apertura hacia arriba","Una línea recta ascendente","Una parábola con apertura hacia abajo"],c:0,
     exp:"f(x) = x² es una función cuadrática cuya gráfica es una <b>parábola con apertura hacia arriba</b> con vértice en el origen (0,0)."},
    {id:"1.6.3",tema:"Límite de una función de una variable real",
     pregunta:"¿Cuál es el lím(x→2) de f(x) = 3x + 1?",
     opts:["7","6","3"],c:0,
     exp:"Para una función continua, el límite se obtiene sustituyendo: lím(x→2) (3x+1) = 3(2)+1 = <b>7</b>. El límite describe el valor al que se aproxima la función."},
    {id:"1.6.4",tema:"Derivadas de funciones polinomiales",
     pregunta:"¿Cuál es la derivada de f(x) = 4x³?",
     opts:["12x²","4x²","3x²"],c:0,
     exp:"Regla de la potencia: d/dx(xⁿ) = n·xⁿ⁻¹. Entonces d/dx(4x³) = 4·3·x² = <b>12x²</b>."},
    {id:"1.6.5",tema:"Derivadas de funciones algebraicas y trascendentes",
     pregunta:"¿Cuál es la derivada de f(x) = sen(x)?",
     opts:["cos(x)","−cos(x)","−sen(x)"],c:0,
     exp:"La derivada de la función seno es la función coseno: d/dx(sen x) = <b>cos(x)</b>. Esta es una derivada de función trascendente básica."},
    {id:"1.6.6",tema:"Aplicación de la derivada en funciones polinomiales de segundo grado en problemas de optimización",
     pregunta:"Para encontrar el máximo o mínimo de f(x) = −x² + 4x, ¿qué operación se realiza primero?",
     opts:["Derivar f(x) e igualar a cero","Integrar f(x)","Factorizar f(x)"],c:0,
     exp:"Para optimizar, se obtiene la <b>derivada f'(x) y se iguala a cero</b>: f'(x) = −2x + 4 = 0; x = 2. Luego se evalúa para determinar si es máximo o mínimo."}
  ]}
]},

{id:2,nombre:"Cultura digital",color:"#bf5fff",colorLight:"#d6f0e2",reactivos:19,subs:[
  {id:"2.1",nombre:"Ciudadanía digital",reactivos:5,temas:[
    {id:"2.1.1",tema:"Elementos de la identidad digital",
     pregunta:"¿Cuál de los siguientes NO forma parte de la identidad digital de una persona?",
     opts:["El número de teléfono fijo de su empresa","Su nombre de usuario en redes sociales","Los contenidos que publica en internet"],c:0,
     exp:"La <b>identidad digital</b> comprende todos los rastros en línea: perfiles, publicaciones, correos, historial de navegación. El teléfono fijo de empresa no es un componente de identidad digital personal."},
    {id:"2.1.2",tema:"Tipos de licenciamiento de software",
     pregunta:"¿Qué tipo de licencia permite usar, modificar y distribuir el software libremente?",
     opts:["Software libre / código abierto","Software propietario","Freeware"],c:0,
     exp:"El <b>software libre (código abierto)</b> otorga las libertades de usar, estudiar, modificar y redistribuir el programa. El propietario restringe estas libertades y el freeware solo permite uso gratuito sin modificación."},
    {id:"2.1.3",tema:"Tipos de servicios digitales",
     pregunta:"Un servicio que permite almacenar archivos en servidores remotos accesibles desde cualquier dispositivo se llama:",
     opts:["Almacenamiento en la nube","Servidor FTP","Red local (LAN)"],c:0,
     exp:"El <b>almacenamiento en la nube</b> (cloud storage) permite guardar y acceder a archivos en servidores remotos a través de internet desde cualquier dispositivo con conexión."},
    {id:"2.1.4",tema:"Tipos de amenazas de seguridad digital",
     pregunta:"Un correo que simula ser de tu banco y te pide ingresar tus datos en una página falsa es un ejemplo de:",
     opts:["Phishing","Ransomware","Troyano"],c:0,
     exp:"El <b>phishing</b> es una técnica de engaño donde se suplanta la identidad de una entidad confiable para robar información personal o financiera mediante páginas o mensajes falsos."},
    {id:"2.1.5",tema:"Medidas de seguridad digital",
     pregunta:"¿Qué medida de seguridad añade una segunda verificación (ej. código SMS) al iniciar sesión?",
     opts:["Autenticación de dos factores (2FA)","Firewall","VPN"],c:0,
     exp:"La <b>autenticación de dos factores (2FA)</b> requiere dos tipos de verificación: algo que sabes (contraseña) y algo que tienes (código temporal). Esto dificulta el acceso no autorizado."}
  ]},
  {id:"2.2",nombre:"Comunicación y colaboración a través de medios digitales",reactivos:5,temas:[
    {id:"2.2.1",tema:"Definición del ciberespacio",
     pregunta:"¿Cómo se define el ciberespacio?",
     opts:["Espacio virtual creado por redes de computadoras e internet","El conjunto de todos los dispositivos electrónicos","El espacio físico donde se ubican los servidores"],c:0,
     exp:"El <b>ciberespacio</b> es el entorno virtual generado por la interconexión de sistemas informáticos y redes digitales, donde se realizan interacciones, comunicaciones e intercambio de información."},
    {id:"2.2.2",tema:"Definición de las TICCAD",
     pregunta:"Las TICCAD son las tecnologías de la información, comunicación, conocimiento y aprendizaje digital. ¿Cuál de las siguientes opciones las describe mejor?",
     opts:["Herramientas digitales que favorecen el aprendizaje colaborativo y la resolución de problemas","Dispositivos electrónicos de uso personal exclusivamente","Aplicaciones para entretenimiento digital"],c:0,
     exp:"Las <b>TICCAD</b> van más allá de las TIC tradicionales: integran el conocimiento y aprendizaje digital como dimensiones fundamentales, orientadas a la formación integral y resolución de problemas contemporáneos."},
    {id:"2.2.3a",tema:"Función y uso de herramientas digitales",
     pregunta:"¿Cuál es la función principal de una plataforma de videoconferencia como herramienta digital colaborativa?",
     opts:["Facilitar la comunicación sincrónica a distancia entre personas","Almacenar documentos en la nube","Proteger la red de virus informáticos"],c:0,
     exp:"Las plataformas de videoconferencia son <b>herramientas de comunicación sincrónica</b> que permiten reuniones, clases y trabajo colaborativo en tiempo real a través de internet."},
    {id:"2.2.3b",tema:"Función y uso de herramientas digitales (2)",
     pregunta:"Google Docs, Microsoft 365 y Notion son ejemplos de herramientas digitales para:",
     opts:["Trabajo colaborativo en documentos en tiempo real","Diseño gráfico profesional","Programación de aplicaciones móviles"],c:0,
     exp:"Estas herramientas permiten que varios usuarios trabajen simultáneamente en el mismo documento, representando el <b>trabajo colaborativo asíncrono y sincrónico</b> en entornos digitales."},
    {id:"2.2.4",tema:"Métodos de investigación digital",
     pregunta:"¿Cuál es una buena práctica al realizar investigación digital?",
     opts:["Verificar la fuente y fecha de publicación de la información","Usar solo el primer resultado del buscador","Copiar y pegar sin citar la fuente"],c:0,
     exp:"Una investigación digital confiable exige <b>evaluar la fuente</b> (autor, institución), la fecha, la objetividad y contrastar con otras fuentes para determinar la veracidad de la información."}
  ]},
  {id:"2.3",nombre:"Creatividad digital",reactivos:5,temas:[
    {id:"2.3.1",tema:"Herramientas del software de hoja de cálculo",
     pregunta:"¿Cuál función de Excel calcula el promedio de un rango de celdas?",
     opts:["=PROMEDIO(rango)","=SUMA(rango)","=CONTAR(rango)"],c:0,
     exp:"La función <b>=PROMEDIO(rango)</b> calcula la media aritmética de los valores en el rango especificado. =SUMA suma los valores y =CONTAR cuenta las celdas con números."},
    {id:"2.3.2",tema:"Herramientas del software de procesamiento de texto",
     pregunta:"¿Cuál herramienta de Word permite revisar la ortografía y gramática automáticamente?",
     opts:["Revisar ortografía y gramática","Buscar y reemplazar","Control de cambios"],c:0,
     exp:"La herramienta <b>Revisar ortografía y gramática</b> analiza el texto y marca posibles errores. 'Buscar y reemplazar' localiza texto, y 'Control de cambios' registra modificaciones al documento."},
    {id:"2.3.3",tema:"Herramientas del software de presentaciones electrónicas",
     pregunta:"¿Qué función de PowerPoint permite que los elementos aparezcan con efectos de movimiento durante la presentación?",
     opts:["Animaciones","Transiciones","Diseño de diapositiva"],c:0,
     exp:"Las <b>animaciones</b> controlan cómo aparecen o se mueven los objetos dentro de una diapositiva. Las transiciones son efectos entre diapositivas, no dentro de ellas."},
    {id:"2.3.4",tema:"Fases del método ADDIE para la creación de contenidos digitales",
     pregunta:"¿Cuáles son las fases del modelo ADDIE en orden correcto?",
     opts:["Análisis, Diseño, Desarrollo, Implementación, Evaluación","Diseño, Análisis, Desarrollo, Evaluación, Implementación","Análisis, Desarrollo, Diseño, Evaluación, Implementación"],c:0,
     exp:"El modelo <b>ADDIE</b> es: <b>A</b>nálysis (Análisis) → <b>D</b>esign (Diseño) → <b>D</b>evelopment (Desarrollo) → <b>I</b>mplementation (Implementación) → <b>E</b>valuation (Evaluación)."},
    {id:"2.3.5",tema:"Campos de aplicación de herramientas tecnológicas",
     pregunta:"¿En cuál de los siguientes campos se aplican las herramientas tecnológicas de realidad aumentada?",
     opts:["Medicina, educación y entretenimiento","Solo telecomunicaciones","Únicamente en videojuegos"],c:0,
     exp:"La <b>realidad aumentada</b> tiene aplicaciones en medicina (cirugías asistidas), educación (visualización 3D), entretenimiento, arquitectura, turismo y muchos otros campos."}
  ]},
  {id:"2.4",nombre:"Pensamiento algorítmico",reactivos:4,temas:[
    {id:"2.4.1",tema:"Conceptos del lenguaje algorítmico",
     pregunta:"En programación, una variable es:",
     opts:["Un espacio en memoria que almacena un valor que puede cambiar","Una instrucción fija del programa","Un tipo de ciclo repetitivo"],c:0,
     exp:"Una <b>variable</b> es un identificador que hace referencia a un espacio en memoria donde se guarda un dato que puede modificarse durante la ejecución del programa."},
    {id:"2.4.2",tema:"Pasos de un algoritmo",
     pregunta:"Para obtener el promedio de 3 calificaciones, ¿cuál es el orden correcto de los pasos?",
     opts:["Leer datos → Sumar → Dividir entre 3 → Mostrar resultado","Mostrar resultado → Leer datos → Sumar → Dividir","Dividir → Sumar → Leer datos → Mostrar resultado"],c:0,
     exp:"Un algoritmo bien estructurado sigue: <b>entrada de datos → procesamiento → salida</b>. Primero se leen los 3 números, luego se suman, se divide entre 3 y finalmente se muestra el promedio."},
    {id:"2.4.3",tema:"Características del pensamiento algorítmico",
     pregunta:"¿Cuál es una característica esencial de un algoritmo?",
     opts:["Debe ser finito y tener un número definido de pasos","Puede tener pasos indefinidos","Solo aplica a computadoras"],c:0,
     exp:"Un <b>algoritmo</b> debe ser: finito (termina en algún punto), preciso (pasos bien definidos), efectivo (produce un resultado correcto) y tener entradas y salidas definidas."},
    {id:"2.4.4",tema:"Símbolos de los diagramas de flujo en algoritmos",
     pregunta:"En un diagrama de flujo, ¿qué figura representa una decisión o condición?",
     opts:["Un rombo (diamante)","Un rectángulo","Un óvalo"],c:0,
     exp:"En los diagramas de flujo: el <b>rombo</b> representa decisiones (sí/no), el rectángulo procesos/operaciones, el óvalo inicio/fin, y el paralelogramo entrada/salida de datos."}
  ]}
]},

{id:3,nombre:"Conciencia histórica",color:"#ff2d78",colorLight:"#ffe8e0",reactivos:23,subs:[
  {id:"3.1",nombre:"Perspectivas del México antiguo y virreinal en los contextos globales",reactivos:6,temas:[
    {id:"3.1.1",tema:"Conquista de los pueblos mesoamericanos o aridoamericanos",
     pregunta:"¿Cuál fue el origen del Palacio Nacional, parte del patrimonio histórico nacional?",
     opts:["Fue construido en la época virreinal como sede del poder político de la Nueva España","Es de origen prehispánico y cumplió función ceremonial mexica","Es de la época moderna y sirvió como domicilio presidencial posrevolucionario"],c:0,
     exp:"El Palacio Nacional tiene su origen durante la época colonial; fue sede del poder virreinal con función administrativa y de gobierno. Los pueblos originarios fueron conquistados durante los siglos XVI a XIX."},
    {id:"3.1.2a",tema:"Movimientos de resistencia de los pueblos originarios y su impacto",
     pregunta:"Los movimientos de resistencia indígena durante la Colonia tenían como objetivo principal:",
     opts:["Defender su territorio, cultura e identidad frente al dominio español","Obtener privilegios comerciales de la Corona","Establecer alianzas permanentes con los conquistadores"],c:0,
     exp:"Los <b>movimientos de resistencia</b> de los pueblos originarios buscaban preservar su territorio, lengua, religión y organización social ante el proceso de conquista y colonización española."},
    {id:"3.1.2b",tema:"Movimientos de resistencia de los pueblos originarios (2)",
     pregunta:"¿Cuál fue una consecuencia del movimiento de resistencia de los pueblos originarios durante la época colonial?",
     opts:["La preservación parcial de lenguas y costumbres indígenas","La total asimilación cultural de los pueblos","La expulsión definitiva de los españoles"],c:0,
     exp:"Gracias a los <b>movimientos de resistencia</b>, muchos pueblos lograron conservar parte de su cultura, lengua y organización comunitaria, aunque bajo condiciones de sometimiento político y económico."},
    {id:"3.1.3",tema:"Grupos sociales de la Nueva España",
     pregunta:"¿Cómo se llamaba el grupo social de la Nueva España conformado por personas nacidas en España peninsular que ocupaban los cargos más altos?",
     opts:["Peninsulares (o gachupines)","Criollos","Mestizos"],c:0,
     exp:"Los <b>peninsulares</b> eran españoles nacidos en España que ocupaban los cargos políticos y eclesiásticos más altos. Los criollos eran hijos de españoles nacidos en América, y los mestizos eran hijos de español e indígena."},
    {id:"3.1.4",tema:"Origen del patrimonio histórico prehispánico y virreinal",
     pregunta:"¿Qué institución en México es responsable de la protección y estudio del patrimonio arqueológico e histórico?",
     opts:["Instituto Nacional de Antropología e Historia (INAH)","SEP","Semarnat"],c:0,
     exp:"El <b>INAH</b> (Instituto Nacional de Antropología e Historia) es la institución encargada de investigar, conservar, proteger y difundir el patrimonio arqueológico, antropológico, histórico y paleontológico de México."},
    {id:"3.1.5",tema:"Preservación del patrimonio histórico prehispánico y virreinal",
     pregunta:"¿Por qué es importante preservar el patrimonio histórico prehispánico y virreinal?",
     opts:["Porque constituye la memoria colectiva e identidad cultural de los pueblos","Porque solo tiene valor económico turístico","Porque pertenece exclusivamente al gobierno federal"],c:0,
     exp:"El <b>patrimonio histórico</b> es la herencia cultural de los pueblos: refleja su historia, identidad y cosmovisión. Su preservación garantiza la transmisión de la memoria colectiva a las generaciones futuras."}
  ]},
  {id:"3.2",nombre:"México durante el expansionismo capitalista",reactivos:11,temas:[
    {id:"3.2.1",tema:"Causas internas y externas de la Independencia",
     pregunta:"¿Cuál fue una causa externa que influyó en el movimiento de Independencia de México?",
     opts:["La invasión napoleónica a España y la crisis de la monarquía española","El descubrimiento de nuevas rutas comerciales hacia Asia","La firma del Tratado de Utrecht"],c:0,
     exp:"La <b>invasión napoleónica a España (1808)</b> y la abdicación de los Reyes en favor de José Bonaparte generaron una crisis de legitimidad que sirvió de detonante para los movimientos independentistas en América."},
    {id:"3.2.2",tema:"Proyectos de emancipación del siglo XIX",
     pregunta:"Los Sentimientos de la Nación, propuesto por Morelos, planteaba la división de poderes, la soberanía popular y:",
     opts:["La abolición de la esclavitud","La alianza con Francia","El mantenimiento del régimen virreinal"],c:0,
     exp:"Los <b>Sentimientos de la Nación</b> (1813) fue el documento redactado por José María Morelos y Pavón en el Congreso de Chilpancingo, que proponía, entre otras cosas, la independencia, la abolición de la esclavitud y la división de poderes."},
    {id:"3.2.3a",tema:"Características e impacto del liberalismo mexicano",
     pregunta:"¿Qué principios caracterizaban al liberalismo mexicano del siglo XIX?",
     opts:["Separación Iglesia-Estado, federalismo y libertades individuales","Centralismo, unión Iglesia-Estado y monarquía","Comunitarismo indígena y colectivismo agrario"],c:0,
     exp:"El <b>liberalismo mexicano</b> del siglo XIX defendía la separación entre la Iglesia y el Estado, el sistema federal, las libertades individuales y la propiedad privada. Sus exponentes más destacados fueron Juárez, Ocampo y Lerdo de Tejada."},
    {id:"3.2.3b",tema:"Características e impacto del liberalismo mexicano (2)",
     pregunta:"Las Leyes de Reforma impulsadas por el liberalismo mexicano en el siglo XIX implicaron principalmente:",
     opts:["La nacionalización de bienes del clero y el registro civil civil","La creación de ejércitos federales","La firma de tratados comerciales con EE.UU."],c:0,
     exp:"Las <b>Leyes de Reforma</b> (1855-1863) separaron la Iglesia del Estado: se nacionalizaron bienes eclesiásticos, se estableció el Registro Civil y el matrimonio civil, y se decretó la libertad de culto."},
    {id:"3.2.4",tema:"Intervenciones de Francia y Estados Unidos en México durante el siglo XIX",
     pregunta:"¿Cuál fue la causa principal de la intervención francesa en México (1862-1867)?",
     opts:["La suspensión del pago de deuda externa decretada por Juárez","Un conflicto fronterizo directo con Francia","La petición de apoyo del Partido Conservador para invadir Texas"],c:0,
     exp:"En 1861, Juárez decretó la suspensión del pago de la deuda externa, lo que motivó la intervención armada de Francia, España e Inglaterra. Francia usó esto como pretexto para imponer el Segundo Imperio Mexicano con Maximiliano."},
    {id:"3.2.5",tema:"Movimientos sociales del siglo XIX",
     pregunta:"¿Qué movimiento social del siglo XIX en México reclamaba la restitución de tierras a las comunidades indígenas despojadas?",
     opts:["Movimiento agrarista indígena","Movimiento obrero urbano","Movimiento federalista criollo"],c:0,
     exp:"Durante el siglo XIX, las comunidades indígenas sufrieron el despojo de sus tierras comunales, lo que generó movimientos sociales que exigían la restitución de tierras. Estos conflictos fueron un antecedente directo de la Revolución Mexicana."},
    {id:"3.2.6",tema:"Consecuencias de la enajenación de bienes comunales",
     pregunta:"¿Cuál fue la principal consecuencia de la enajenación de bienes comunales en el siglo XIX?",
     opts:["El despojo de tierras indígenas y su concentración en manos de hacendados","El fortalecimiento económico de los pueblos indígenas","La diversificación de la propiedad rural"],c:0,
     exp:"Las leyes de desamortización (Ley Lerdo, 1856) obligaron a vender tierras comunales, lo que provocó el <b>despojo masivo de comunidades indígenas</b> y la concentración de tierras en pocas manos (latifundismo)."},
    {id:"3.2.7",tema:"Características del porfiriato",
     pregunta:"¿Cuál fue una característica económica del porfiriato (1876-1911)?",
     opts:["Fuerte inversión extranjera en minería, ferrocarriles y petróleo","Reparto masivo de tierras a campesinos","Industrialización nacional con capital mexicano"],c:0,
     exp:"Durante el <b>porfiriato</b>, el modelo de desarrollo se basó en la atracción de capital extranjero (principalmente estadounidense, inglés y francés) para desarrollar minería, ferrocarriles, petróleo y agricultura de exportación, generando crecimiento desigual."},
    {id:"3.2.8",tema:"Movimientos de oposición al porfiriato",
     pregunta:"El Partido Liberal Mexicano (PLM) de los hermanos Flores Magón fue un movimiento de oposición al porfiriato que promovía:",
     opts:["Libertades políticas, derechos laborales y reforma agraria","La restauración de la monarquía habsburgo","Alianzas con el gobierno de Porfirio Díaz"],c:0,
     exp:"El <b>PLM</b>, fundado por Ricardo Flores Magón, publicó el periódico Regeneración y el Programa del PLM (1906), que exigía libertades civiles, jornadas laborales justas y reforma agraria, convirtiéndose en un antecedente ideológico de la Revolución."},
    {id:"3.2.9",tema:"Facciones de la Revolución mexicana",
     pregunta:"Durante la Revolución mexicana, la facción zapatista tomó los estados de Guerrero y Morelos y plasmó sus ideas en el:",
     opts:["Plan de Ayala","Plan de San Luis","Plan de Guadalupe"],c:0,
     exp:"La <b>facción zapatista</b>, encabezada por Emiliano Zapata, desarrolló su lucha en Morelos y propugnaba la restitución de tierras despojadas a los campesinos. El Plan de Ayala (1911) fue su principal documento programático."},
    {id:"3.2.10",tema:"Impacto de la Revolución mexicana",
     pregunta:"¿Cuál fue el principal legado jurídico de la Revolución Mexicana?",
     opts:["La Constitución de 1917, que incluía derechos sociales como tierra, trabajo y educación","La firma del Tratado de Guadalupe Hidalgo","La promulgación de las Leyes de Reforma"],c:0,
     exp:"La <b>Constitución de 1917</b> fue el principal legado de la Revolución: incorporó por primera vez en el mundo derechos sociales como el derecho a la tierra (Art. 27), al trabajo (Art. 123) y la educación laica y gratuita (Art. 3°)."}
  ]},
  {id:"3.3",nombre:"La realidad actual en perspectiva histórica",reactivos:6,temas:[
    {id:"3.3.1",tema:"Factores de consolidación del presidencialismo",
     pregunta:"¿Cuál fue un factor que consolidó el presidencialismo en México durante el siglo XX?",
     opts:["La concentración de facultades en el ejecutivo y la hegemonía del PRI","La vigencia de un sistema parlamentario equilibrado","El fortalecimiento del poder judicial independiente"],c:0,
     exp:"El <b>presidencialismo mexicano</b> se consolidó gracias a la concentración de poderes en el ejecutivo, el sistema de partido hegemónico (PRI), el control de los sindicatos y la subordinación de los otros poderes al presidente."},
    {id:"3.3.2",tema:"Participación de México en eventos históricos internacionales del siglo XX",
     pregunta:"¿Cuál fue la postura de México durante la Guerra Fría respecto a Cuba?",
     opts:["México mantuvo relaciones diplomáticas con Cuba cuando otros países las rompieron","México apoyó el bloqueo económico de Cuba promovido por EE.UU.","México envió tropas para apoyar al gobierno cubano"],c:0,
     exp:"México mantuvo su <b>política exterior de no intervención</b> y continuó sus relaciones diplomáticas con Cuba, incluso cuando la OEA la expulsó en 1962. Esto reflejó la doctrina Estrada de respeto a la autodeterminación."},
    {id:"3.3.3",tema:"Causas del neoliberalismo en México",
     pregunta:"¿Qué proceso económico internacional impulsó la adopción del modelo neoliberal en México durante los años 80?",
     opts:["La crisis de la deuda, las políticas del FMI y el Banco Mundial","La Segunda Guerra Mundial y la reconstrucción europea","El auge del socialismo en América Latina"],c:0,
     exp:"La <b>crisis de la deuda de 1982</b> obligó a México a aceptar los programas de ajuste estructural del FMI y BM, que exigían privatizaciones, apertura comercial y reducción del Estado, instaurando el modelo neoliberal."},
    {id:"3.3.4",tema:"Globalización en la actualidad",
     pregunta:"¿Cuál es una consecuencia de la globalización en la economía mexicana?",
     opts:["Integración a cadenas productivas globales y dependencia de mercados internacionales","Autosuficiencia alimentaria y producción local exclusiva","Cierre de fronteras comerciales para proteger la industria nacional"],c:0,
     exp:"La <b>globalización</b> integró a México en cadenas de producción y comercio mundiales (ejemplo: manufactura automotriz y electrónica para exportación), pero también generó dependencia de mercados externos y vulnerabilidad ante crisis internacionales."},
    {id:"3.3.5",tema:"Causas de la alternancia política",
     pregunta:"¿Cuál fue el año en que se produjo la primera alternancia política en la presidencia de México?",
     opts:["2000","1994","2006"],c:0,
     exp:"En el año <b>2000</b>, Vicente Fox Quesada del PAN ganó la presidencia, lo que representó la primera alternancia política en México después de más de 70 años de hegemonía del PRI, culminando un proceso de democratización gradual."},
    {id:"3.3.6",tema:"Impacto social de los medios de comunicación en la historia",
     pregunta:"¿Cuál fue el impacto de la televisión en la sociedad mexicana del siglo XX?",
     opts:["Homogeneización cultural y formación de una opinión pública nacional","Fortalecimiento exclusivo de la identidad regional","Reducción del consumo de medios impresos sin otros efectos"],c:0,
     exp:"La <b>televisión</b> en México (desde los años 50) contribuyó a la homogeneización cultural, la formación de referentes nacionales comunes, la difusión de valores y la influencia en la opinión pública y los procesos electorales."}
  ]}
]},

{id:4,nombre:"Humanidades",color:"#ff9f0a",colorLight:"#e8e4ff",reactivos:20,subs:[
  {id:"4.1",nombre:"Fundamentos del pensamiento filosófico",reactivos:4,temas:[
    {id:"4.1.1",tema:"Filosofía, mito y ciencia",
     pregunta:"¿En qué se diferencia el conocimiento científico del conocimiento mítico?",
     opts:["El científico es verificable y sistemático; el mítico es narrativo y simbólico","El científico es subjetivo; el mítico es objetivo","Ambos utilizan el mismo método de verificación"],c:0,
     exp:"El <b>conocimiento científico</b> busca explicaciones verificables, reproducibles y sistemáticas. El <b>conocimiento mítico</b> ofrece explicaciones narrativas y simbólicas del mundo a través de relatos sagrados o cosmogónicos."},
    {id:"4.1.2",tema:"Pensamiento crítico",
     pregunta:"¿Cuál es la característica esencial del pensamiento crítico?",
     opts:["Analizar, evaluar y cuestionar la información de manera razonada antes de aceptarla","Aceptar toda información de fuentes oficiales sin cuestionarla","Rechazar sistemáticamente todas las teorías establecidas"],c:0,
     exp:"El <b>pensamiento crítico</b> implica analizar con rigor los argumentos, evaluar la evidencia, identificar falacias y sesgos, y llegar a conclusiones fundamentadas en la razón, no en la autoridad o la emoción."},
    {id:"4.1.3",tema:"Pensamiento existencialista",
     pregunta:"¿Cuál es el principio central del existencialismo según Sartre?",
     opts:["La existencia precede a la esencia: el ser humano se define por sus actos","La esencia del ser humano está predeterminada por Dios","La razón es la única fuente de conocimiento válido"],c:0,
     exp:"Para Sartre, '<b>la existencia precede a la esencia</b>': el ser humano primero existe, luego se define mediante sus elecciones y actos. No hay naturaleza humana fija; somos lo que hacemos con nuestra libertad."},
    {id:"4.1.4",tema:"Doxa y episteme",
     pregunta:"En filosofía griega, ¿cómo se distingue la doxa de la episteme?",
     opts:["La doxa es opinión o creencia; la episteme es conocimiento verdadero y justificado","La doxa es conocimiento científico; la episteme es creencia popular","Ambos términos significan lo mismo: conocimiento racional"],c:0,
     exp:"Para Platón, la <b>doxa</b> (δόξα) es la opinión o creencia sobre el mundo sensible, mutable y no siempre verdadera. La <b>episteme</b> (ἐπιστήμη) es el conocimiento verdadero, justificado y universal, propio del mundo de las ideas."}
  ]},
  {id:"4.2",nombre:"Elementos para el desarrollo del pensamiento y de la argumentación",reactivos:4,temas:[
    {id:"4.2.1",tema:"Funciones de la lengua",
     pregunta:"En el texto de Kant: «Obra solo según aquella máxima por la cual puedas querer que se convierta en ley universal», ¿qué función de la lengua predomina?",
     opts:["Instrumental (directiva)","Emotiva (expresiva)","Informativa (referencial)"],c:0,
     exp:"La <b>función instrumental o directiva</b> busca influir en la conducta del receptor mediante imperativos o mandatos. El texto de Kant usa un imperativo ('Obra solo según…') para prescribir una norma de conducta universal."},
    {id:"4.2.2",tema:"Premisas y conclusión del argumento",
     pregunta:"En el argumento: 'Todos los humanos son mortales. Sócrates es humano. Por lo tanto, Sócrates es mortal', ¿cuántas premisas hay?",
     opts:["Dos premisas y una conclusión","Una premisa y una conclusión","Tres premisas"],c:0,
     exp:"Un argumento tiene <b>premisas</b> (afirmaciones que sostienen el razonamiento) y una <b>conclusión</b> (lo que se deriva). En este silogismo clásico hay dos premisas y una conclusión ('Por lo tanto…')."},
    {id:"4.2.3",tema:"Argumentos deductivos, inductivos y analógicos",
     pregunta:"¿Qué tipo de argumento va de lo particular a lo general?",
     opts:["Inductivo","Deductivo","Analógico"],c:0,
     exp:"El argumento <b>inductivo</b> parte de casos particulares para llegar a una conclusión general (ej: 'He observado que todos los cuervos son negros, por lo tanto todos los cuervos son negros'). El deductivo va de lo general a lo particular."},
    {id:"4.2.4",tema:"Tipos de discurso argumentativo",
     pregunta:"¿Cuál es el método socrático que consiste en llegar a la verdad mediante preguntas y respuestas?",
     opts:["Mayéutica","Debate","Deliberación"],c:0,
     exp:"La <b>mayéutica</b> es el método filosófico de Sócrates: mediante preguntas sucesivas guiaba a su interlocutor para que extrajera el conocimiento de sí mismo. El debate enfrenta posiciones opuestas y la deliberación busca consensos grupales."}
  ]},
  {id:"4.3",nombre:"Construcción de la persona para la convivencia",reactivos:3,temas:[
    {id:"4.3.1",tema:"Postulados de las teorías éticas",
     pregunta:"¿Cuál es el postulado central de la ética kantiana (deontológica)?",
     opts:["Actuar conforme al deber y la razón universal, independientemente de las consecuencias","Buscar siempre la mayor felicidad para el mayor número de personas","Actuar según la virtud y el justo medio"],c:0,
     exp:"La <b>ética deontológica de Kant</b> sostiene que la moralidad se basa en el deber (deon) y en la razón: una acción es moral si se puede universalizar como ley. Las consecuencias no determinan la moralidad del acto."},
    {id:"4.3.2",tema:"Los valores y su definición",
     pregunta:"Relacione: Libertad = independencia del individuo; Justicia = decisión bien/mal universal; Solidaridad = actuar por el grupo; Respeto = comprender a otros. ¿Qué combinación es correcta?",
     opts:["1-Libertad:independencia, 2-Justicia:universal, 3-Solidaridad:grupo, 4-Respeto:tolerancia","1-Justicia:independencia, 2-Libertad:tolerancia, 3-Respeto:grupo, 4-Solidaridad:universal","1-Solidaridad:universal, 2-Respeto:independencia, 3-Justicia:grupo, 4-Libertad:tolerancia"],c:0,
     exp:"Los valores y sus definiciones: <b>Libertad</b> = independencia del individuo. <b>Justicia</b> = decidir entre bien y mal desde perspectiva universal. <b>Solidaridad</b> = actuar en interés del grupo. <b>Respeto</b> = interés por comprender a otros con tolerancia."},
    {id:"4.3.3",tema:"Tipos de normas",
     pregunta:"¿Cuál es la diferencia entre una norma jurídica y una norma moral?",
     opts:["La jurídica es obligatoria y coercitiva; la moral es interna y no tiene sanción externa","La moral es más importante que la jurídica","Ambas tienen el mismo tipo de sanción"],c:0,
     exp:"Las <b>normas jurídicas</b> son impuestas por el Estado, son coercitivas (tienen sanción legal externa). Las <b>normas morales</b> son internalizadas por el individuo y su sanción es interna (culpa, vergüenza) o social (rechazo)."}
  ]},
  {id:"4.4",nombre:"Reflexión política y participación ciudadana",reactivos:2,temas:[
    {id:"4.4.1",tema:"Autonomía y heteronomía",
     pregunta:"Según Kant, una persona actúa con autonomía moral cuando:",
     opts:["Sus acciones se guían por leyes que ella misma se impone racionalmente","Obedece las normas impuestas por la autoridad externa","Actúa según las tradiciones culturales de su comunidad"],c:0,
     exp:"La <b>autonomía</b> (autos=uno mismo, nomos=ley) significa darse la propia ley. Para Kant, el ser autónomo actúa por convicción racional propia. La <b>heteronomía</b> es actuar por normas externas impuestas (ley, religión, costumbre)."},
    {id:"4.4.2",tema:"Discurso político",
     pregunta:"¿Cuál es la función principal del discurso político?",
     opts:["Persuadir e influir en la opinión y comportamiento de la ciudadanía respecto al poder","Proporcionar información neutral sobre hechos históricos","Transmitir conocimientos científicos a la sociedad"],c:0,
     exp:"El <b>discurso político</b> tiene como función central persuadir a los ciudadanos, legitimar el poder, construir identidades colectivas e influir en la toma de decisiones públicas. Combina argumentación, retórica y estrategia comunicativa."}
  ]},
  {id:"4.5",nombre:"La humanidad ante los desafíos contemporáneos",reactivos:5,temas:[
    {id:"4.5.1",tema:"Principios de bioética",
     pregunta:"Una empresa dona alimentos a personas en situación de calle para combatir la desnutrición. ¿A qué principio bioético responde?",
     opts:["Beneficencia","Justicia","No maleficencia"],c:0,
     exp:"La <b>beneficencia</b> implica actuar en favor del bienestar de otros. La no maleficencia es no causar daño. La justicia es dar a cada quien lo que corresponde equitativamente. La acción de la empresa se orienta al beneficio activo de las personas vulnerables."},
    {id:"4.5.2",tema:"Principios éticos aplicados a la sustentabilidad",
     pregunta:"¿Qué principio ético orienta el desarrollo sustentable?",
     opts:["Responsabilidad intergeneracional: satisfacer necesidades presentes sin comprometer las futuras","Maximización del consumo en el presente","Prioridad absoluta del crecimiento económico"],c:0,
     exp:"El <b>desarrollo sustentable</b> (Brundtland, 1987) se basa en el principio de <b>responsabilidad intergeneracional</b>: satisfacer las necesidades actuales sin comprometer la capacidad de las generaciones futuras de satisfacer las suyas."},
    {id:"4.5.3",tema:"Perspectiva de género",
     pregunta:"¿Qué estudia la perspectiva de género?",
     opts:["Las construcciones sociales y culturales que determinan los roles asignados a hombres y mujeres","Las diferencias biológicas entre hombres y mujeres","Las preferencias personales de cada individuo"],c:0,
     exp:"La <b>perspectiva de género</b> analiza cómo la sociedad construye roles, expectativas y relaciones de poder entre los géneros. A diferencia del sexo (biológico), el género es una construcción sociocultural que puede transformarse."},
    {id:"4.5.4",tema:"Reconocimiento de la alteridad",
     pregunta:"El concepto filosófico de 'alteridad' hace referencia a:",
     opts:["El reconocimiento del otro como diferente pero igualmente valioso","La negación de la existencia del otro","La imposición de la propia cultura sobre los demás"],c:0,
     exp:"La <b>alteridad</b> (del latín alter = otro) es el reconocimiento filosófico del otro en su diferencia. Implica comprender que existen otras formas de ser, pensar y vivir igualmente válidas, fundamento del diálogo intercultural."},
    {id:"4.5.5",tema:"Relación entre humanos y otros seres vivos",
     pregunta:"¿Qué perspectiva ética defiende que los animales tienen valor intrínseco y derechos?",
     opts:["Ética animal o biocéntrica","Antropocentrismo","Utilitarismo clásico"],c:0,
     exp:"La <b>ética biocéntrica</b> reconoce valor intrínseco a todos los seres vivos, no solo a los humanos. Filósofos como Peter Singer (utilitarismo) y Tom Regan (derechos animales) argumentan que los animales merecen consideración moral."}
  ]},
  {id:"4.6",nombre:"Reflexiones sobre el arte, el sentimiento y la sensibilidad",reactivos:2,temas:[
    {id:"4.6.1",tema:"Categorías estéticas",
     pregunta:"¿Cuál de las siguientes es una categoría estética?",
     opts:["Lo sublime","La justicia","La verdad"],c:0,
     exp:"Las <b>categorías estéticas</b> son conceptos que organizan la experiencia artística: lo bello, lo sublime, lo trágico, lo cómico, lo grotesco. Lo sublime (Burke, Kant) se asocia a la experiencia de algo grandioso que supera nuestra comprensión."},
    {id:"4.6.2",tema:"Definición de hermenéutica",
     pregunta:"¿Qué estudia la hermenéutica?",
     opts:["La teoría y práctica de la interpretación de textos y obras","La creación de obras artísticas originales","La percepción sensorial del ser humano"],c:0,
     exp:"La <b>hermenéutica</b> (del griego Hermes, mensajero) es la disciplina filosófica dedicada a la teoría e interpretación de textos, obras de arte y expresiones culturales. Gadamer y Ricoeur son sus principales representantes contemporáneos."}
  ]}
]},

{id:5,nombre:"Ciencias naturales, experimentales y tecnología",color:"#00fff0",colorLight:"#ddeeff",reactivos:32,subs:[
  {id:"5.1",nombre:"La materia y sus interacciones",reactivos:5,temas:[
    {id:"5.1.1",tema:"Tipos de enlaces (iónico, covalente y metálico)",
     pregunta:"¿Cuál compuesto químico forma un enlace iónico?",
     opts:["NaCl","H₂O","O₂"],c:0,
     exp:"El <b>NaCl</b> (cloruro de sodio) se forma por transferencia de electrones del Na al Cl, generando iones Na⁺ y Cl⁻ que se atraen electrostáticamente: enlace <b>iónico</b>. El H₂O tiene enlace covalente polar y el O₂ tiene enlace covalente apolar."},
    {id:"5.1.2",tema:"Características de los estados de agregación de la materia",
     pregunta:"¿Cuál es la característica del estado gaseoso de la materia?",
     opts:["No tiene forma ni volumen definidos; se expande para llenar el recipiente","Tiene forma definida y volumen fijo","Tiene volumen fijo pero adopta la forma del recipiente"],c:0,
     exp:"El estado <b>gaseoso</b> se caracteriza por no tener forma ni volumen fijos: las partículas se mueven libremente y se expanden para ocupar todo el volumen disponible. El sólido tiene forma y volumen fijos; el líquido tiene volumen fijo pero adopta la forma del recipiente."},
    {id:"5.1.3",tema:"Ley de la conservación de la materia",
     pregunta:"La Ley de Lavoisier establece que en una reacción química:",
     opts:["La masa total de reactivos es igual a la masa total de productos","Se crea nueva materia a partir de energía","La materia desaparece al transformarse en energía"],c:0,
     exp:"La <b>Ley de Conservación de la Materia</b> (Lavoisier, 1789) establece que en toda reacción química la masa se conserva: 'En la naturaleza nada se crea ni se destruye, solo se transforma.'"},
    {id:"5.1.4",tema:"Conversión de escalas termométricas",
     pregunta:"¿Cuál es la equivalencia de 100°C en Kelvin?",
     opts:["373 K","273 K","100 K"],c:0,
     exp:"La conversión de Celsius a Kelvin es: K = °C + 273. Entonces 100°C + 273 = <b>373 K</b>. El cero absoluto (0 K) equivale a −273°C, la temperatura más baja teóricamente posible."},
    {id:"5.1.5",tema:"Ley de Coulomb",
     pregunta:"Según la Ley de Coulomb, la fuerza entre dos cargas eléctricas:",
     opts:["Aumenta al acercar las cargas y disminuye al alejarlas","Es constante independientemente de la distancia","Solo actúa entre cargas del mismo signo"],c:0,
     exp:"La <b>Ley de Coulomb</b> establece que la fuerza entre dos cargas es directamente proporcional al producto de las cargas e inversamente proporcional al cuadrado de la distancia. Al acercarlas, la fuerza aumenta; al alejarlas, disminuye."}
  ]},
  {id:"5.2",nombre:"Conservación de la energía y sus interacciones con la materia",reactivos:5,temas:[
    {id:"5.2.1",tema:"Características de la luz visible",
     pregunta:"¿Cuál es la velocidad aproximada de la luz en el vacío?",
     opts:["300,000 km/s","150,000 km/s","30,000 km/s"],c:0,
     exp:"La velocidad de la luz en el vacío es aproximadamente <b>300,000 km/s</b> (3×10⁸ m/s). La luz visible es parte del espectro electromagnético, con longitudes de onda entre 380 y 700 nanómetros."},
    {id:"5.2.2",tema:"Calor específico",
     pregunta:"El calor específico de una sustancia indica:",
     opts:["La energía necesaria para elevar 1°C la temperatura de 1 gramo de esa sustancia","La temperatura a la que una sustancia cambia de estado","La capacidad de una sustancia para conducir electricidad"],c:0,
     exp:"El <b>calor específico</b> es la cantidad de calor (en Joules o calorías) necesaria para elevar 1°C (o 1K) la temperatura de 1 gramo de una sustancia. El agua tiene un calor específico alto (4.18 J/g·°C), lo que la hace excelente regulador térmico."},
    {id:"5.2.3",tema:"Características de los tipos de energía",
     pregunta:"¿Cuál es la diferencia entre energía renovable y no renovable?",
     opts:["La renovable se regenera naturalmente; la no renovable se agota con el uso","La renovable es más costosa que la no renovable","Solo la no renovable puede generar electricidad"],c:0,
     exp:"Las <b>energías renovables</b> (solar, eólica, hídrica, geotérmica) se regeneran naturalmente y no se agotan. Las <b>no renovables</b> (petróleo, gas, carbón) se formaron en millones de años y su consumo las agota progresivamente."},
    {id:"5.2.4",tema:"Energía cinética y potencial",
     pregunta:"¿Qué tipo de energía posee una pelota que está cayendo desde lo alto de un edificio?",
     opts:["Tiene energía potencial (por su posición) que se transforma en cinética (por el movimiento)","Solo energía cinética","Solo energía potencial gravitacional"],c:0,
     exp:"Al caer, la <b>energía potencial gravitacional</b> (Ep = mgh) se transforma en <b>energía cinética</b> (Ec = ½mv²). Esta transformación ilustra la conservación de la energía mecánica."},
    {id:"5.2.5",tema:"Leyes de la termodinámica",
     pregunta:"¿Qué establece la Ley Cero de la Termodinámica?",
     opts:["Si dos sistemas están en equilibrio térmico con un tercero, están en equilibrio entre sí","La energía del universo se conserva","El calor no puede pasar espontáneamente de un cuerpo frío a uno caliente"],c:0,
     exp:"La <b>Ley Cero</b> establece el concepto de equilibrio térmico: si A está en equilibrio con C, y B está en equilibrio con C, entonces A y B están en equilibrio entre sí. Los bloques de hielo en contacto son un ejemplo."}
  ]},
  {id:"5.3",nombre:"Ecosistemas: interacciones, energía y dinámica",reactivos:7,temas:[
    {id:"5.3.1",tema:"Productos y reactivos en la fotosíntesis",
     pregunta:"¿Cuáles son los productos de la fotosíntesis?",
     opts:["Glucosa y oxígeno","CO₂ y agua","Glucosa y CO₂"],c:0,
     exp:"La <b>fotosíntesis</b>: 6CO₂ + 6H₂O + luz → C₆H₁₂O₆ + 6O₂. Los reactivos son CO₂ y agua; los productos son <b>glucosa y oxígeno</b>. Ocurre en los cloroplastos de las plantas mediante la clorofila."},
    {id:"5.3.2",tema:"Características de los biomas",
     pregunta:"¿Cuál de los siguientes biomas se caracteriza por escasas precipitaciones y grandes variaciones de temperatura entre día y noche?",
     opts:["Desierto","Tundra","Selva tropical"],c:0,
     exp:"El <b>desierto</b> se caracteriza por precipitaciones menores a 250 mm anuales, vegetación escasa y adaptada (cactáceas), y grandes variaciones térmicas diarias. La tundra tiene permafrost y la selva tropical tiene alta humedad y biodiversidad."},
    {id:"5.3.3",tema:"Niveles de las redes tróficas",
     pregunta:"¿Cuál es el papel de los descomponedores en las redes tróficas?",
     opts:["Descomponen materia orgánica y devuelven nutrientes al suelo","Producen energía solar","Son depredadores del nivel más alto"],c:0,
     exp:"Los <b>descomponedores</b> (hongos, bacterias) degradan la materia orgánica muerta y la transforman en compuestos inorgánicos, devolviendo nutrientes al suelo y cerrando los ciclos biogeoquímicos. Sin ellos, los ecosistemas se saturarían de materia muerta."},
    {id:"5.3.4",tema:"Sustancias en los ciclos biogeoquímicos",
     pregunta:"¿Qué ciclo biogeoquímico es fundamental para la síntesis de proteínas en los organismos?",
     opts:["Ciclo del nitrógeno","Ciclo del carbono","Ciclo del agua"],c:0,
     exp:"El <b>ciclo del nitrógeno</b> es esencial para la vida: el N₂ atmosférico se fija por bacterias del suelo, se incorpora a aminoácidos y proteínas, y regresa a la atmósfera por desnitrificación. Sin nitrógeno asimilable no hay síntesis proteica."},
    {id:"5.3.5",tema:"Tipos de productividad en un ecosistema",
     pregunta:"La productividad primaria neta de un ecosistema es:",
     opts:["La energía que queda disponible para los consumidores después de la respiración del productor","Toda la energía capturada en la fotosíntesis","La energía consumida por los herbívoros"],c:0,
     exp:"La <b>productividad primaria neta (PPN)</b> = Productividad primaria bruta − Respiración del productor. Es la energía que queda almacenada en la biomasa vegetal y disponible para los consumidores del siguiente nivel trófico."},
    {id:"5.3.6",tema:"Tipos de servicios ambientales",
     pregunta:"La polinización de cultivos por abejas es un ejemplo de servicio ambiental:",
     opts:["De soporte (aprovisionamiento directo)","Cultural","De regulación"],c:0,
     exp:"Los <b>servicios ambientales de provisión</b> incluyen alimentos, agua, madera. Los <b>de regulación</b> incluyen control del clima, purificación del agua. Los <b>culturales</b> son recreativos y estéticos. La polinización es un servicio de soporte/provisión que permite la producción de alimentos."},
    {id:"5.3.7",tema:"Consecuencias del desequilibrio ecológico",
     pregunta:"¿Cuál es una consecuencia directa del desequilibrio ecológico causado por la deforestación?",
     opts:["Pérdida de biodiversidad, erosión del suelo y alteración del ciclo del agua","Aumento de la productividad agrícola a largo plazo","Reducción del efecto invernadero"],c:0,
     exp:"La <b>deforestación</b> genera: pérdida de hábitats y biodiversidad, erosión del suelo al perder cobertura vegetal, alteración del ciclo hídrico (menos evapotranspiración), aumento de CO₂ atmosférico y contribución al cambio climático."}
  ]},
  {id:"5.4",nombre:"Reacciones químicas y conservación de la materia",reactivos:3,temas:[
    {id:"5.4.1",tema:"Masa molar de los compuestos químicos",
     pregunta:"¿Cuál es la masa molar aproximada del agua (H₂O)? (H=1, O=16)",
     opts:["18 g/mol","16 g/mol","34 g/mol"],c:0,
     exp:"La <b>masa molar</b> se calcula sumando las masas atómicas de todos los átomos: H₂O = 2(1) + 16 = <b>18 g/mol</b>. La masa molar indica cuántos gramos equivalen a un mol (6.022×10²³ partículas) de una sustancia."},
    {id:"5.4.2",tema:"Tipos de reacciones químicas",
     pregunta:"En la reacción: 2H₂ + O₂ → 2H₂O, ¿qué tipo de reacción química es?",
     opts:["Síntesis o combinación","Descomposición","Desplazamiento simple"],c:0,
     exp:"La reacción es de <b>síntesis o combinación</b>: dos o más sustancias se combinan para formar una sola. En la descomposición, una sustancia se divide en dos o más. En el desplazamiento, un elemento reemplaza a otro."},
    {id:"5.4.3",tema:"Tipos de reacciones nucleares (fusión y fisión)",
     pregunta:"¿Cuál es la diferencia entre fisión y fusión nuclear?",
     opts:["La fisión divide núcleos pesados; la fusión une núcleos ligeros","La fisión une núcleos ligeros; la fusión divide núcleos pesados","Ambas dividen el núcleo atómico"],c:0,
     exp:"La <b>fisión</b> divide núcleos pesados (como Uranio-235) liberando gran energía (reactores nucleares). La <b>fusión</b> une núcleos ligeros (como hidrógeno) liberando aún más energía (el Sol, bombas de hidrógeno). La fusión controlada sería la fuente de energía casi ilimitada del futuro."}
  ]},
  {id:"5.5",nombre:"La energía en los procesos de la vida diaria",reactivos:4,temas:[
    {id:"5.5.1",tema:"Tipos de choques (elástico e inelástico)",
     pregunta:"¿Cuál es la característica de un choque perfectamente elástico?",
     opts:["Se conserva tanto la cantidad de movimiento como la energía cinética","Solo se conserva la cantidad de movimiento","Se conserva la energía cinética pero no el momentum"],c:0,
     exp:"En un <b>choque elástico</b> se conservan tanto el momentum (cantidad de movimiento) como la energía cinética. En el <b>inelástico</b> se conserva el momentum pero parte de la energía cinética se transforma en calor, sonido u otras formas."},
    {id:"5.5.2",tema:"Momento lineal",
     pregunta:"¿Cuál es la fórmula del momento lineal (cantidad de movimiento)?",
     opts:["p = m × v","p = F × t","p = ½mv²"],c:0,
     exp:"El <b>momento lineal</b> (o cantidad de movimiento) se define como: <b>p = m × v</b>, donde m es la masa y v la velocidad. El teorema impulso-momento establece que la variación del momento es igual al impulso aplicado."},
    {id:"5.5.3",tema:"Ondas electromagnéticas en dispositivos de uso cotidiano",
     pregunta:"¿Qué tipo de onda electromagnética usa el horno de microondas para calentar alimentos?",
     opts:["Microondas","Rayos X","Luz infrarroja"],c:0,
     exp:"El <b>horno de microondas</b> usa ondas de microondas (frecuencia ~2.45 GHz) que vibran las moléculas de agua en los alimentos, generando calor por fricción molecular. Los rayos X se usan en diagnóstico médico; la luz infrarroja, en termografía y mandos a distancia."},
    {id:"5.5.4",tema:"Caída libre",
     pregunta:"Un objeto cae desde el reposo en caída libre. Ignorando la resistencia del aire, ¿con qué aceleración cae?",
     opts:["9.8 m/s² (aceleración gravitacional g)","5 m/s²","0 m/s² (velocidad constante)"],c:0,
     exp:"En <b>caída libre</b>, los objetos caen con la aceleración gravitacional g ≈ <b>9.8 m/s²</b>, independientemente de su masa (Galileo). La velocidad aumenta 9.8 m/s cada segundo y la distancia crece como d = ½gt²."}
  ]},
  {id:"5.6",nombre:"Organismos: estructura y procesos",reactivos:3,temas:[
    {id:"5.6.1",tema:"Organelos celulares",
     pregunta:"¿Cuál organelo celular es conocido como la 'central energética' de la célula?",
     opts:["Mitocondria","Ribosoma","Vacuola"],c:0,
     exp:"La <b>mitocondria</b> es el organelo donde se realiza la respiración celular aeróbica y se produce ATP (energía). Los ribosomas sintetizan proteínas y las vacuolas almacenan agua, nutrientes y desechos."},
    {id:"5.6.2",tema:"Niveles de organización biológica",
     pregunta:"¿Cuál es el orden correcto de los niveles de organización biológica?",
     opts:["Átomo → Molécula → Célula → Tejido → Órgano → Sistema → Organismo","Célula → Tejido → Molécula → Órgano → Organismo","Molécula → Organismo → Célula → Tejido → Sistema"],c:0,
     exp:"Los <b>niveles de organización biológica</b> van de menor a mayor complejidad: Átomo → Molécula → Orgánulo → <b>Célula → Tejido → Órgano → Sistema (aparato) → Organismo</b> → Población → Comunidad → Ecosistema → Biosfera."},
    {id:"5.6.3",tema:"Etapas de la respiración celular",
     pregunta:"En la primera etapa de la respiración celular (glucólisis), se rompe una molécula de glucosa para obtener:",
     opts:["2 piruvatos y energía (ATP)","CO₂ y agua","Acetil-CoA directamente"],c:0,
     exp:"La <b>glucólisis</b> es la primera etapa de la respiración celular: ocurre en el citoplasma y convierte una molécula de glucosa (C₆) en <b>2 piruvatos</b> (C₃), produciendo 2 ATP y 2 NADH. No requiere oxígeno."}
  ]},
  {id:"5.7",nombre:"Herencia y evolución biológica",reactivos:5,temas:[
    {id:"5.7.1",tema:"Reproducción sexual y asexual",
     pregunta:"¿Cuál es la ventaja principal de la reproducción sexual respecto a la asexual?",
     opts:["Genera mayor variabilidad genética, lo que favorece la adaptación evolutiva","Es más rápida y requiere menos energía","Produce descendientes idénticos al progenitor"],c:0,
     exp:"La <b>reproducción sexual</b> combina material genético de dos progenitores, generando variabilidad genética en la descendencia, lo que favorece la adaptación al ambiente y la evolución. La asexual produce clones y es más eficiente pero menos adaptable."},
    {id:"5.7.2",tema:"Tipos de cromosomas",
     pregunta:"¿Cuántos pares de cromosomas tiene la especie humana?",
     opts:["23 pares (46 cromosomas)","24 pares (48 cromosomas)","22 pares (44 cromosomas)"],c:0,
     exp:"Los humanos tienen <b>46 cromosomas</b> organizados en <b>23 pares</b>: 22 pares de autosomas y 1 par de cromosomas sexuales (XX en mujeres, XY en hombres). El cariotipo humano fue descrito en 1956 por Tjio y Levan."},
    {id:"5.7.3",tema:"Cuadros de Punnett",
     pregunta:"Si un padre Aa (heterocigoto) se cruza con una madre Aa, ¿qué probabilidad hay de obtener descendencia aa (homocigoto recesivo)?",
     opts:["25%","50%","75%"],c:0,
     exp:"Cruce Aa × Aa: el cuadro de Punnett da AA (25%), Aa (50%), aa (25%). La probabilidad de obtener fenotipo recesivo (aa) es del <b>25%</b>. Los cuadros de Punnett son herramientas para predecir la herencia mendeliana."},
    {id:"5.7.4",tema:"Teorías evolutivas",
     pregunta:"¿Cuál es el mecanismo central de la teoría de la evolución de Darwin?",
     opts:["Selección natural: sobreviven los individuos con variaciones más adaptadas al ambiente","Herencia de caracteres adquiridos durante la vida","Mutaciones dirigidas hacia la perfección de las especies"],c:0,
     exp:"La <b>selección natural</b> (Darwin, 1859) establece que los individuos con variaciones hereditarias que les confieren ventajas para sobrevivir y reproducirse en su ambiente dejan más descendientes, propagando esas variaciones en la población."},
    {id:"5.7.5",tema:"Consecuencias de la evolución",
     pregunta:"¿Cuál es una consecuencia de la evolución biológica?",
     opts:["La aparición de nuevas especies (especiación) y la extinción de otras","La permanencia de las especies sin cambios a lo largo del tiempo","La evolución solo afecta a los microorganismos"],c:0,
     exp:"La evolución tiene múltiples consecuencias: <b>especiación</b> (origen de nuevas especies), adaptaciones morfológicas y fisiológicas, extinción de especies menos adaptadas, y la diversificación de la vida en la Tierra que podemos observar hoy."}
  ]}
]},

{id:6,nombre:"Lengua y comunicación",color:"#ff2d78",colorLight:"#d6f0d6",reactivos:31,subs:[
  {id:"6.1",nombre:"Estrategias de comprensión lectora",reactivos:4,temas:[
    {id:"6.1.1",tema:"Título del texto expositivo",
     pregunta:"¿Cuál es la función principal del título en un texto expositivo?",
     opts:["Anticipar el tema central y orientar la lectura del texto","Decorar el texto y hacerlo más atractivo","Indicar la extensión del texto"],c:0,
     exp:"El <b>título del texto expositivo</b> cumple función referencial: anuncia el tema que se va a tratar, orienta al lector sobre el contenido y sirve como clave para activar conocimientos previos que facilitan la comprensión lectora."},
    {id:"6.1.2",tema:"Tipos de relaciones lógicas entre oraciones",
     pregunta:"El conector 'sin embargo' establece una relación de:",
     opts:["Contraste o adversidad","Causa-efecto","Adición"],c:0,
     exp:"'<b>Sin embargo</b>' es un conector adversativo que establece una relación de <b>contraste o concesión</b> entre dos ideas. Otros adversativos: pero, no obstante, a pesar de, aunque. Los causales son: porque, ya que, puesto que."},
    {id:"6.1.3",tema:"Jerarquía de la información en mapas conceptuales",
     pregunta:"¿Qué función cumple el concepto central (nodo principal) en un mapa conceptual?",
     opts:["Es el concepto más general del que se desprenden los demás","Es un detalle específico del tema","Sirve de conectivo entre dos ideas secundarias"],c:0,
     exp:"En un <b>mapa conceptual</b> (Novak), el nodo central o concepto rector es el más general e inclusivo; de él se desprenden jerárquicamente los conceptos más específicos, conectados mediante palabras de enlace que expresan relaciones."},
    {id:"6.1.4",tema:"Tipos de formas textuales de comunicación",
     pregunta:"¿Cuál es la característica principal de un resumen?",
     opts:["Reproduce de forma abreviada las ideas principales de un texto","Incluye la opinión personal del autor sobre el texto","Amplía y desarrolla la información del texto original"],c:0,
     exp:"El <b>resumen</b> condensa fielmente las ideas principales de un texto sin añadir opiniones del redactor. La <b>reseña</b> también describe y evalúa; el <b>comentario crítico</b> añade análisis valorativo propio."}
  ]},
  {id:"6.2",nombre:"Recursos del análisis literario",reactivos:6,temas:[
    {id:"6.2.1",tema:"Tema central del texto literario narrativo",
     pregunta:"¿Cómo se define el tema central de un texto narrativo literario?",
     opts:["La idea principal o asunto abstracto que articula toda la obra","El nombre del protagonista de la historia","El lugar donde se desarrolla la acción"],c:0,
     exp:"El <b>tema</b> de un texto narrativo es la idea abstracta central que articula la obra: puede ser el amor, la traición, la búsqueda de identidad, etc. Es diferente del argumento (lo que pasa) y del motivo (imagen recurrente)."},
    {id:"6.2.2",tema:"Trama del texto literario narrativo",
     pregunta:"¿Qué es la trama en un texto narrativo?",
     opts:["La secuencia causal de eventos que constituyen la historia","El punto más emocionante de la historia","El inicio de la narración"],c:0,
     exp:"La <b>trama</b> (o trama narrativa) es la organización causal de los eventos de la historia: la relación causa-efecto entre las acciones. Difiere del argumento (simple sucesión de hechos) en que implica conexión lógica y motivacional."},
    {id:"6.2.3",tema:"Características y acciones de los personajes",
     pregunta:"¿Cómo se denomina al personaje que representa el obstáculo principal que debe superar el protagonista?",
     opts:["Antagonista","Deuteragonista","Personaje secundario"],c:0,
     exp:"El <b>antagonista</b> es el personaje (u fuerza) que se opone al protagonista y genera el conflicto central de la narrativa. El deuteragonista es el segundo personaje en importancia; los secundarios apoyan o complementan la acción."},
    {id:"6.2.4",tema:"Características del narrador",
     pregunta:"¿Qué tipo de narrador cuenta la historia en primera persona usando 'yo'?",
     opts:["Narrador protagonista (homodiegético)","Narrador omnisciente (heterodiegético)","Narrador testigo"],c:0,
     exp:"El <b>narrador protagonista</b> (homodiegético, según Genette) es el personaje principal que narra desde su propia perspectiva usando la primera persona. El omnisciente narra en tercera persona con conocimiento total; el testigo es un personaje secundario que observa."},
    {id:"6.2.5",tema:"Ámbito de la narración",
     pregunta:"¿Qué comprende el ámbito de la narración en un texto literario?",
     opts:["El espacio y el tiempo en que se desarrollan los hechos","Solo los personajes principales","El estilo y vocabulario del autor"],c:0,
     exp:"El <b>ámbito de la narración</b> incluye el espacio (lugar físico o simbólico donde ocurren los hechos) y el tiempo (época, duración, momento histórico). Ambos configuran el contexto que da sentido a los eventos y comportamientos de los personajes."},
    {id:"6.2.6",tema:"Tipos de tiempo narrativo",
     pregunta:"Cuando una narración interrumpe la historia presente para contar un evento pasado, se usa:",
     opts:["Analepsis (flashback)","Prolepsis (flashforward)","In medias res"],c:0,
     exp:"La <b>analepsis</b> (o flashback) es un recurso narrativo que interrumpe el presente para relatar eventos anteriores. La prolepsis anticipa eventos futuros. El in medias res inicia la narración en medio de la acción."}
  ]},
  {id:"6.3",nombre:"Procesos de composición de textos",reactivos:7,temas:[
    {id:"6.3.1",tema:"Etapas para la composición de un ensayo",
     pregunta:"¿Cuáles son las etapas básicas del proceso de composición de un ensayo?",
     opts:["Planeación → Redacción (borrador) → Revisión → Edición final","Revisión → Planeación → Redacción → Publicación","Redacción → Corrección → Planeación → Publicación"],c:0,
     exp:"El proceso de escritura de un ensayo incluye: <b>Planeación</b> (selección del tema, tesis, esquema) → <b>Borrador</b> (redacción inicial) → <b>Revisión</b> (contenido, coherencia, estilo) → <b>Edición</b> (corrección ortotipográfica y presentación final)."},
    {id:"6.3.2",tema:"Tipos de fuentes de información",
     pregunta:"Un diario personal y una entrevista directa son ejemplos de fuentes:",
     opts:["Primarias","Secundarias","Terciarias"],c:0,
     exp:"Las <b>fuentes primarias</b> son documentos originales de primera mano: testimonios directos, diarios, entrevistas, obras literarias originales, datos de investigación. Las secundarias interpretan o analizan fuentes primarias (libros de texto, reseñas)."},
    {id:"6.3.3",tema:"Reglas de acentuación",
     pregunta:"La palabra 'examen' es:",
     opts:["Llana sin tilde (termina en consonante n, no lleva acento escrito)","Aguda con tilde","Esdrújula con tilde"],c:0,
     exp:"'<b>Examen</b>' es una palabra <b>llana</b> (el acento fonético recae en la penúltima sílaba: EX-a-men). Las llanas NO llevan tilde cuando terminan en vocal, n o s. Termina en 'n', por lo que no lleva tilde escrita."},
    {id:"6.3.4",tema:"Reglas de puntuación",
     pregunta:"'El profesor llegó con retraso___ Los alumnos estaban ansiosos.' ¿Qué signo de puntuación va en el espacio?",
     opts:["Punto y seguido","Coma","Punto y coma"],c:0,
     exp:"Se usa el <b>punto y seguido</b> para separar oraciones independientes dentro de un mismo párrafo que tratan el mismo tema. La coma separa elementos dentro de una oración; el punto y coma separa oraciones relacionadas de estructura más compleja."},
    {id:"6.3.5",tema:"Función de unidades sintácticas",
     pregunta:"En la oración 'El estudiante estudia mucho', ¿cuál es el sujeto?",
     opts:["El estudiante","estudia","mucho"],c:0,
     exp:"El <b>sujeto</b> es la unidad sintáctica que realiza la acción del verbo o de quien se habla. En 'El estudiante estudia mucho', el sujeto es 'El estudiante' (núcleo: estudiante + determinante: el). El predicado es 'estudia mucho'."},
    {id:"6.3.6",tema:"Coherencia de un texto",
     pregunta:"¿Qué es la coherencia textual?",
     opts:["La unidad temática y lógica que hace que todas las partes del texto se relacionen con el tema central","El uso correcto de la ortografía y puntuación","La longitud equilibrada de los párrafos"],c:0,
     exp:"La <b>coherencia</b> es la propiedad textual por la que todas las ideas del texto se relacionan lógicamente con el tema central, evitando contradicciones y digresiones. Es diferente de la cohesión (mecanismos formales de conexión)."},
    {id:"6.3.7",tema:"Adecuación de un texto",
     pregunta:"¿Qué es la adecuación textual?",
     opts:["La propiedad de adaptar el registro y el tono del texto a la situación comunicativa y al receptor","Escribir textos muy largos y detallados","Usar vocabulario técnico en todo tipo de texto"],c:0,
     exp:"La <b>adecuación</b> es la propiedad por la que el texto se adapta a la situación comunicativa: al receptor (formal/informal), al canal (escrito/oral), al propósito (informar, persuadir) y al tema. Un texto adecuado usa el registro apropiado."}
  ]},
  {id:"6.4",nombre:"Formas orales de la comunicación",reactivos:4,temas:[
    {id:"6.4.1",tema:"Elementos de la exposición oral",
     pregunta:"¿Cuál es el elemento central de una buena exposición oral?",
     opts:["Claridad, organización del contenido y adaptación al público","Hablar muy rápido para cubrir todo el tema","Leer literalmente las diapositivas proyectadas"],c:0,
     exp:"Una <b>exposición oral</b> efectiva requiere: <b>claridad</b> (ideas comprensibles), <b>organización</b> (introducción-desarrollo-conclusión), <b>adaptación al público</b> (vocabulario y ritmo apropiados), contacto visual y apoyo de recursos visuales pertinentes."},
    {id:"6.4.2",tema:"Características del diálogo",
     pregunta:"¿Cuál es la característica que distingue al diálogo de otras formas orales?",
     opts:["La alternancia de turnos entre dos o más interlocutores","La presencia de un solo hablante que se dirige a una audiencia","La ausencia de retroalimentación inmediata"],c:0,
     exp:"El <b>diálogo</b> se caracteriza por la <b>alternancia de turnos</b>: dos o más participantes intercambian mensajes con retroalimentación inmediata (feedback). A diferencia del monólogo, todos los participantes son alternativamente emisores y receptores."},
    {id:"6.4.3",tema:"Elementos del debate",
     pregunta:"¿Cuál es el elemento esencial del debate como forma oral de comunicación?",
     opts:["La confrontación de posiciones opuestas con argumentos fundamentados","El acuerdo entre todos los participantes desde el inicio","La ausencia de réplica entre los participantes"],c:0,
     exp:"El <b>debate</b> es una forma de comunicación oral en la que dos o más participantes defienden posiciones contrarias sobre un tema mediante argumentos estructurados. Sus elementos: moderador, participantes, tema polémico, argumentos y réplicas."},
    {id:"6.4.4",tema:"Funciones de las formas orales de la comunicación",
     pregunta:"Una asamblea comunitaria donde los vecinos discuten y deciden sobre un proyecto local es un ejemplo de comunicación oral con función:",
     opts:["Deliberativa (toma de decisiones colectivas)","Meramente informativa unidireccional","Estética o poética"],c:0,
     exp:"La <b>función deliberativa</b> de la comunicación oral busca llegar a acuerdos y tomar decisiones colectivas mediante la discusión y el debate. Otras funciones: informativa (transmitir datos), persuasiva (convencer), estética (valor artístico)."}
  ]},
  {id:"6.5",nombre:"Estructura gramatical del idioma inglés",reactivos:10,temas:[
    {id:"6.5.1",tema:"Tiempo presente",
     pregunta:"Complete: 'John _______ basketball every Saturday. He _______ TV in the morning because he _______ to go for a jog.'",
     opts:["plays / doesn't watch / prefers","plays / don't watch / prefers","play / doesn't watch / prefer"],c:0,
     exp:"Third person singular in simple present: add -s/-es to the verb. <b>plays</b> (play+s), <b>doesn't watch</b> (does + not + base verb), <b>prefers</b> (prefer+s). Don't is used with I/you/we/they; doesn't with he/she/it."},
    {id:"6.5.2",tema:"Tiempo pasado",
     pregunta:"Complete with simple past: 'Yesterday, she _______ (go) to the library and _______ (study) for three hours.'",
     opts:["went / studied","gone / studyed","go / studied"],c:0,
     exp:"Simple past: irregular verbs change form (<b>go → went</b>); regular verbs add -ed (<b>study → studied</b>, note y→ied). Simple past describes completed actions at a specific time in the past."},
    {id:"6.5.3",tema:"Tiempo futuro",
     pregunta:"Complete: 'Thanks for lending me your bike. I _______ give it back on Monday.'",
     opts:["will","would","am going to"],c:0,
     exp:"'<b>Will</b>' is used for promises, decisions made at the moment of speaking, and predictions. 'Would' is for hypothetical situations (conditionals). 'Am going to' is for previously planned intentions."},
    {id:"6.5.4",tema:"Presente perfecto",
     pregunta:"Complete: 'I _______ never _______ sushi before. This is my first time.'",
     opts:["have / eaten","has / eat","had / eaten"],c:0,
     exp:"Present perfect: <b>have/has + past participle</b>. With 'I' we use <b>have eaten</b>. The present perfect connects past experience with the present moment. 'Never' and 'ever' are common adverbs with this tense."},
    {id:"6.5.5",tema:"Pasado perfecto",
     pregunta:"Complete: 'Gonzalo Guerrero arrived in Mexico in 1511. By 1519, he _______ adopted a Mayan lifestyle.'",
     opts:["had","has","have"],c:0,
     exp:"Past perfect: <b>had + past participle</b>. It describes an action completed before another past event. 'By 1519' signals that the adoption happened before 1519 (another past reference point). Structure: <b>had adopted</b>."},
    {id:"6.5.6",tema:"Preguntas wh-",
     pregunta:"Complete the wh- question: '_______ did you go on vacation last summer?'",
     opts:["Where","What","Who"],c:0,
     exp:"<b>Where</b> asks about place/location. What asks about things or information. Who asks about people. The sentence refers to a vacation destination, so <b>Where</b> is the correct wh- word. Structure: Wh- word + auxiliary (did) + subject + base verb."},
    {id:"6.5.7",tema:"Relaciones de comparación",
     pregunta:"Complete: 'Mount Everest is _______ mountain in the world.' (tall)",
     opts:["the tallest","taller than","more tall"],c:0,
     exp:"Superlative form: for short adjectives, add -est with 'the': <b>the tallest</b>. Comparative (taller than) compares two things. 'More tall' is incorrect; the correct comparative is 'taller' (short adjective). Irregular: good→better→best; bad→worse→worst."},
    {id:"6.5.8",tema:"Verbos modales",
     pregunta:"Complete: 'You _______ wear a seatbelt in the car. It's the law.' (obligación)",
     opts:["must","might","could"],c:0,
     exp:"<b>Must</b> expresses strong obligation or necessity (often from the speaker or a rule). <b>Might</b> expresses possibility. <b>Could</b> expresses past ability or polite requests. For legal obligation: must/have to are both correct."},
    {id:"6.5.9",tema:"Estructuras condicionales",
     pregunta:"Complete (second conditional): 'If I _______ a million dollars, I _______ travel the world.'",
     opts:["had / would","have / will","had / will"],c:0,
     exp:"Second conditional (hypothetical/unreal present): <b>If + past simple, would + base verb</b>. Structure: If I <b>had</b> (past simple) a million dollars, I <b>would</b> travel the world. First conditional uses: If + present simple, will + base verb."},
    {id:"6.5.10",tema:"Voz pasiva",
     pregunta:"Change to passive voice: 'The teacher corrects the exams.'",
     opts:["The exams are corrected by the teacher.","The exams is corrected by the teacher.","The exams were corrected by the teacher."],c:0,
     exp:"Passive voice (present simple): <b>Subject + am/is/are + past participle + by + agent</b>. 'The exams' (plural) → <b>are</b> corrected. The agent 'by the teacher' can be omitted if unknown or unimportant."}
  ]}
]},

{id:7,nombre:"Ciencias sociales",color:"#bf5fff",colorLight:"#f0e0ff",reactivos:25,subs:[
  {id:"7.1",nombre:"Organización económica",reactivos:9,temas:[
    {id:"7.1.1",tema:"Necesidades materiales vitales y no vitales",
     pregunta:"Una persona fallece por hipotermia al no tener ropa adecuada en un frente frío. ¿Qué tipo de necesidad quedó insatisfecha?",
     opts:["Necesidad vital (básica para sobrevivir)","Necesidad no vital (mejora el bienestar)","Necesidad cultural"],c:0,
     exp:"Las <b>necesidades vitales</b> son indispensables para la supervivencia: alimento, vestido, vivienda, agua. Su insatisfacción puede causar la muerte. Las necesidades no vitales mejoran la calidad de vida pero no son imprescindibles para sobrevivir."},
    {id:"7.1.2",tema:"Factores de los procesos de producción",
     pregunta:"¿Cuáles son los factores clásicos de producción en economía?",
     opts:["Tierra, trabajo y capital","Dinero, tecnología y mercado","Empresa, gobierno y consumidor"],c:0,
     exp:"Los factores clásicos de producción son: <b>Tierra</b> (recursos naturales), <b>Trabajo</b> (esfuerzo humano) y <b>Capital</b> (bienes de producción: maquinaria, herramientas). La economía moderna añade la <b>tecnología</b> y el <b>conocimiento</b> como factores."},
    {id:"7.1.3",tema:"Tipos de sectores productivos",
     pregunta:"La producción agrícola, ganadera y minera pertenece al sector:",
     opts:["Primario","Secundario","Terciario"],c:0,
     exp:"El <b>sector primario</b> incluye actividades que extraen recursos de la naturaleza: agricultura, ganadería, pesca, minería y silvicultura. El secundario transforma materias primas (manufactura, construcción). El terciario presta servicios."},
    {id:"7.1.4",tema:"Mecanismos de distribución de la riqueza",
     pregunta:"¿Cuál de los siguientes es un mecanismo de distribución de la riqueza?",
     opts:["El salario como retribución al trabajo","La producción de bienes de consumo","El ahorro personal"],c:0,
     exp:"Los mecanismos de <b>distribución de la riqueza</b> son los medios por los que el ingreso generado en la producción se reparte entre los factores productivos: salarios (trabajo), ganancias (capital), rentas (tierra) e intereses."},
    {id:"7.1.5",tema:"Empleo formal e informal",
     pregunta:"¿Cuál es la característica del empleo informal?",
     opts:["No está registrado, no tiene seguridad social ni prestaciones legales","Tiene contrato firmado y todos los beneficios legales","Solo se refiere al trabajo doméstico no remunerado"],c:0,
     exp:"El <b>empleo informal</b> carece de registro ante las autoridades, no paga impuestos, no tiene acceso a seguridad social, ni prestaciones como vacaciones o aguinaldo. En México representa más del 55% de la ocupación total."},
    {id:"7.1.6",tema:"Mecanismos estatales de redistribución de la riqueza",
     pregunta:"¿Cuál es un mecanismo estatal para redistribuir la riqueza?",
     opts:["Los programas sociales financiados con impuestos progresivos","La libre competencia en el mercado","El ahorro voluntario de los ciudadanos"],c:0,
     exp:"El Estado redistribuye la riqueza mediante <b>impuestos progresivos</b> (más pagan quienes más tienen) y <b>gasto social</b> (programas de salud, educación, subsidios). Estos mecanismos buscan reducir la desigualdad de ingresos."},
    {id:"7.1.7",tema:"Características del Estado de bienestar",
     pregunta:"¿Cuál es una característica del Estado de bienestar?",
     opts:["El Estado garantiza servicios básicos universales: salud, educación y seguridad social","El Estado no interviene en la economía","El mercado es el único distribuidor de bienes y servicios"],c:0,
     exp:"El <b>Estado de bienestar</b> (welfare state) se caracteriza por la intervención activa del Estado para garantizar derechos sociales universales: salud, educación, pensiones, vivienda, seguro de desempleo. Surgió en Europa occidental tras la Segunda Guerra Mundial."},
    {id:"7.1.8",tema:"Características del modelo económico neoliberal",
     pregunta:"¿Cuál es una característica del modelo neoliberal?",
     opts:["Privatización de empresas públicas, reducción del Estado y apertura comercial","Nacionalización de industrias estratégicas","Proteccionismo y subsidios a la industria nacional"],c:0,
     exp:"El <b>neoliberalismo</b> propugna: libre mercado, privatización de empresas estatales, reducción del gasto público, desregulación, apertura comercial (libre comercio) y contención de la inflación. Se aplicó en México desde los años 80."},
    {id:"7.1.9",tema:"Degradación ambiental por las formas de producción",
     pregunta:"¿Cuál forma de producción genera mayor degradación ambiental?",
     opts:["La agricultura industrial intensiva con agroquímicos y monocultivos","La agricultura de subsistencia tradicional","La producción artesanal local"],c:0,
     exp:"La <b>agricultura industrial intensiva</b> usa agroquímicos (pesticidas, fertilizantes sintéticos) que contaminan suelos y acuíferos, genera monocultivos que reducen la biodiversidad, provoca erosión y compactación del suelo, y contribuye a la emisión de GEI."}
  ]},
  {id:"7.2",nombre:"Perspectivas políticas",reactivos:8,temas:[
    {id:"7.2.1",tema:"Teorías sobre el origen del Estado",
     pregunta:"¿Cuál filósofo planteó que el Estado surge de un contrato social para salir del 'estado de naturaleza' donde 'la vida es solitaria, pobre, sucia, brutal y corta'?",
     opts:["Thomas Hobbes","Jean-Jacques Rousseau","John Locke"],c:0,
     exp:"<b>Thomas Hobbes</b> (Leviatán, 1651) argumentó que en el estado de naturaleza reina la guerra de todos contra todos, por lo que los individuos ceden sus derechos a un soberano absoluto para garantizar la paz. Rousseau veía el estado natural como bueno, corrompido por la sociedad."},
    {id:"7.2.2",tema:"Características de la democracia electoral",
     pregunta:"¿Cuál es una característica esencial de la democracia electoral?",
     opts:["Elecciones periódicas, libres y competitivas para elegir representantes","La gobernanza por un partido único vitalicio","Las decisiones las toma un grupo de técnicos no electos"],c:0,
     exp:"La <b>democracia electoral</b> se basa en elecciones periódicas, libres, competitivas y con sufragio universal, donde los ciudadanos eligen a sus representantes. Implica también pluripartidismo, libertad de expresión y garantías para la oposición."},
    {id:"7.2.3",tema:"Requisitos para obtener la ciudadanía mexicana",
     pregunta:"En México, ¿a qué edad se adquiere la ciudadanía según la Constitución?",
     opts:["A los 18 años","A los 21 años","Al contraer matrimonio"],c:0,
     exp:"Según el <b>Artículo 34 de la Constitución Política de México</b>, son ciudadanos los mexicanos que hayan cumplido <b>18 años</b> y tengan un modo honesto de vivir. La ciudadanía otorga el derecho a votar y ser votado."},
    {id:"7.2.4",tema:"Función de las instituciones del Estado mexicano",
     pregunta:"¿Cuál es la función del Centro Nacional de Prevención de Desastres (Cenapred)?",
     opts:["Promover acciones para prever, reducir y controlar el riesgo de desastres naturales","Regular el comercio exterior","Supervisar el sistema de salud nacional"],c:0,
     exp:"El <b>Cenapred</b> es la institución del Estado mexicano encargada de investigar, monitorear y generar políticas públicas para la gestión integral del riesgo de desastres, contribuyendo al bienestar y seguridad de la sociedad."},
    {id:"7.2.5",tema:"Poderes fácticos",
     pregunta:"¿Qué son los poderes fácticos?",
     opts:["Grupos con gran influencia política y económica que actúan fuera del marco legal formal","Los tres poderes formales: ejecutivo, legislativo y judicial","Los estados y municipios del sistema federal"],c:0,
     exp:"Los <b>poderes fácticos</b> son actores con gran influencia real sobre las decisiones políticas aunque no tienen una posición formal en el gobierno: medios de comunicación, grandes empresas, iglesias, sindicatos y, en algunos contextos, el crimen organizado."},
    {id:"7.2.6",tema:"Principios de política exterior del Estado mexicano",
     pregunta:"¿Cuál es uno de los principios de la política exterior mexicana consagrados en el Artículo 89 constitucional?",
     opts:["No intervención en asuntos internos de otros países","Alianza militar obligatoria con Estados Unidos","Expansionismo territorial en América Latina"],c:0,
     exp:"La política exterior de México se rige por principios como: <b>no intervención</b>, autodeterminación de los pueblos, solución pacífica de controversias, proscripción de la amenaza o el uso de la fuerza, y cooperación para el desarrollo."},
    {id:"7.2.7",tema:"Organismos internacionales",
     pregunta:"¿Cuál es la función principal de la Organización de las Naciones Unidas (ONU)?",
     opts:["Mantener la paz y seguridad internacional, promover el desarrollo y los derechos humanos","Regular el comercio mundial entre países","Administrar las reservas monetarias internacionales"],c:0,
     exp:"La <b>ONU</b> (fundada en 1945) tiene como propósitos: mantener la paz y seguridad internacionales, fomentar relaciones de amistad entre naciones, promover el progreso social y los derechos humanos. El Banco Mundial y el FMI son organismos financieros distintos."},
    {id:"7.2.8",tema:"Áreas en el sistema mundo",
     pregunta:"Según la teoría del sistema-mundo de Wallerstein, ¿cómo se clasifican los países?",
     opts:["En centro (países dominantes), semiperiferia y periferia (países dependientes)","En países desarrollados y subdesarrollados exclusivamente","En democracias, autocracias y teocracias"],c:0,
     exp:"Wallerstein propone que el capitalismo global organiza a los países en tres áreas: <b>Centro</b> (países dominantes con economías avanzadas), <b>Semiperiferia</b> (países intermedios como México) y <b>Periferia</b> (países dependientes que proveen materias primas)."}
  ]},
  {id:"7.3",nombre:"Problemas sociológicos",reactivos:8,temas:[
    {id:"7.3.1",tema:"Tipos de organización social",
     pregunta:"La familia es la unidad social básica en la que se apoya el Estado; la comunidad agrupa individuos con lazos culturales comunes; la clase social agrupa según posición económica. ¿Qué combinación es correcta?",
     opts:["Familia=unidad básica, Comunidad=lazos culturales, Clase=posición económica","Familia=lazos culturales, Comunidad=posición económica, Clase=unidad básica","Familia=posición económica, Comunidad=unidad básica, Clase=lazos culturales"],c:0,
     exp:"<b>Familia</b>: unidad social básica que apoya el desarrollo del Estado. <b>Comunidad</b>: agrupación con relaciones interpersonales, espacio geográfico y hábitos culturales comunes. <b>Clase social</b>: grupos que se diferencian por su posición en el sistema económico."},
    {id:"7.3.2",tema:"Indicadores de desarrollo comunitario",
     pregunta:"¿Cuál de los siguientes es un indicador de desarrollo comunitario?",
     opts:["Acceso a servicios básicos: agua potable, drenaje, electricidad y escuelas","El PIB nacional total del país","La tasa de inflación anual"],c:0,
     exp:"Los <b>indicadores de desarrollo comunitario</b> miden la calidad de vida a nivel local: cobertura de servicios básicos, tasa de alfabetización, acceso a salud, infraestructura, participación ciudadana y niveles de pobreza en la comunidad."},
    {id:"7.3.3",tema:"Indicadores de bienestar",
     pregunta:"¿Cuál es un indicador de bienestar social?",
     opts:["El Índice de Desarrollo Humano (IDH), que combina esperanza de vida, educación e ingreso","El Producto Interno Bruto (PIB) total","La tasa de exportaciones"],c:0,
     exp:"El <b>Índice de Desarrollo Humano (IDH)</b> del PNUD mide tres dimensiones: <b>salud</b> (esperanza de vida), <b>educación</b> (años de escolaridad) e <b>ingreso</b> (INB per cápita). Va más allá del PIB al incorporar dimensiones cualitativas del bienestar."},
    {id:"7.3.4",tema:"Factores que propician la segregación social",
     pregunta:"¿Cuál de los siguientes factores propicia la segregación social?",
     opts:["La discriminación por origen étnico, género, clase social o discapacidad","La educación inclusiva de calidad","El acceso universal a servicios públicos"],c:0,
     exp:"La <b>segregación social</b> es la separación de grupos sociales basada en características como etnia, clase económica, género, religión o discapacidad. La discriminación sistémica, la desigualdad de oportunidades y los prejuicios culturales son sus principales factores."},
    {id:"7.3.5",tema:"Derechos de las niñas, niños y adolescentes",
     pregunta:"¿Cuál es el principio rector de la Convención sobre los Derechos del Niño de la ONU?",
     opts:["El interés superior del niño debe ser consideración primordial en todas las decisiones que les afecten","Los niños solo tienen derechos cuando alcanzan la mayoría de edad","Los derechos del niño son subordinados a los de los adultos"],c:0,
     exp:"El <b>interés superior del niño</b> es el principio rector de la Convención sobre los Derechos del Niño (CDN, 1989): en toda decisión o acción que afecte a un menor, se debe dar primacía a su bienestar y desarrollo integral."},
    {id:"7.3.6",tema:"Consecuencias de las crisis sociales, económicas y ambientales en la sociedad mexicana",
     pregunta:"¿Cuál fue una consecuencia social de la crisis económica de 1994 (Error de diciembre) en México?",
     opts:["Aumento del desempleo, incremento de la pobreza y crecimiento de la economía informal","Reducción de la desigualdad social","Fortalecimiento del peso mexicano"],c:0,
     exp:"La <b>crisis de 1994</b> ('Error de diciembre') provocó la devaluación del peso, aumento del desempleo, caída del poder adquisitivo, incremento de la pobreza y expansión de la economía informal. Tuvo impacto en toda América Latina ('Efecto Tequila')."},
    {id:"7.3.7",tema:"Tipos de migraciones",
     pregunta:"¿Cuál es la diferencia entre migración interna e internacional?",
     opts:["La interna ocurre dentro del mismo país; la internacional implica cruzar fronteras nacionales","La interna es temporal y la internacional permanente siempre","La interna es voluntaria y la internacional siempre es forzada"],c:0,
     exp:"La <b>migración interna</b> es el desplazamiento dentro de las fronteras del propio país (ej: del campo a la ciudad). La <b>migración internacional</b> implica cruzar fronteras entre países. Ambas pueden ser voluntarias (económicas) o forzadas (conflictos, desastres)."},
    {id:"7.3.8",tema:"Movimientos sociales antisistema",
     pregunta:"¿Cuál de los siguientes es un ejemplo de movimiento social antisistema?",
     opts:["El movimiento zapatista (EZLN) que cuestiona el modelo económico neoliberal","Un partido político que participa en elecciones para llegar al gobierno","Una empresa que implementa políticas de responsabilidad social"],c:0,
     exp:"Los <b>movimientos antisistema</b> cuestionan radicalmente el orden político, económico o social vigente y no buscan integrarse en él sino transformarlo o sustituirlo. El EZLN (1994) es un ejemplo que combinó demandas indígenas con crítica al neoliberalismo."}
  ]}
]}
];


let qState = {
  screen: "welcome",
  areaId: null,
  subId: null,
  answers: JSON.parse(localStorage.getItem("acredita_q180")||"{}"),
};
function qSaveAnswers(){ localStorage.setItem("acredita_q180", JSON.stringify(qState.answers)); }

function qAreaStats(area){
  let total=0,ok=0,answered=0;
  area.subs.forEach(s=>s.temas.forEach(t=>{
    total++;const a=qState.answers[t.id];
    if(a!==undefined){answered++;if(a===t.c)ok++;}
  }));
  return{total,ok,answered,err:answered-ok};
}
function qGlobalStats(){
  let total=0,ok=0,answered=0;
  AREAS_QUIZ.forEach(a=>{const s=qAreaStats(a);total+=s.total;ok+=s.ok;answered+=s.answered;});
  return{total,ok,answered,err:answered-ok};
}
function qSubStats(sub){
  let total=sub.temas.length,ok=0,answered=0;
  sub.temas.forEach(t=>{const a=qState.answers[t.id];if(a!==undefined){answered++;if(a===t.c)ok++;}});
  return{total,ok,answered};
}

function qSyncScoreBar(){
  const gs=qGlobalStats();
  const el=document.getElementById('score-display');
  if(el) el.textContent=`Correctas: ${gs.ok}  |  Racha: ${quizStreak} 🔥`;
  const pts=document.getElementById('qsb-pts');
  if(pts) pts.textContent=`${gs.ok*10} pts`;
  const st=document.getElementById('qsb-streak');
  if(st) st.textContent=`Racha: ${quizStreak} 🔥`;
  const fill=document.getElementById('qprogress-fill');
  if(fill) fill.style.width=`${gs.total?Math.round(gs.answered/gs.total*100):0}%`;
  // sync header pill
  const hp=document.getElementById('hs-pts');
  const hs=document.getElementById('hs-streak');
  if(hp) hp.textContent=gs.ok*10;
  if(hs) hs.textContent=`${quizStreak}🔥`;
}

function qUpdate(){
  qSyncScoreBar();
  qRenderSidebar();
  if(qState.screen==="welcome") qRenderWelcome();
  else if(qState.screen==="quiz") qRenderDetail();
  else if(qState.screen==="final") qRenderFinal();
  buildAreaBar();
}

function qRenderSidebar(){
  let h="";
  AREAS_QUIZ.forEach(a=>{
    const st=qAreaStats(a);
    const isActive=qState.screen==="quiz"&&qState.areaId===a.id;
    h+=`<div><div class="qsb-area-head ${isActive?"qa-active":""}" onclick="qToggleSbArea(${a.id})">
      <span class="qsb-area-name">${a.id}. ${a.nombre}</span>
      <span class="qsb-area-stat">${st.ok}/${st.total}</span>
      <span class="qsb-chevron" id="qchev-${a.id}">▶</span>
    </div><div class="qsb-subs ${isActive?"open":""}" id="qsbsub-${a.id}">`;
    a.subs.forEach(s=>{
      const ss=qSubStats(s);
      const isSub=qState.screen==="quiz"&&qState.subId===s.id;
      const done=ss.answered===ss.total&&ss.total>0;
      h+=`<div class="qsb-sub-item ${isSub?"qsub-active":""} ${done&&!isSub?"qsub-done":""}" onclick="qGoQuiz(${a.id},'${s.id}')">
        <span>${s.nombre}</span><span class="qsb-sub-stat">${ss.ok}/${ss.total}</span>
      </div>`;
    });
    h+=`</div></div>`;
  });
  const el=document.getElementById('qsb-areas');
  if(el) el.innerHTML=h;
}

function qToggleSbArea(id){
  const el=document.getElementById("qsbsub-"+id);
  const chev=document.getElementById("qchev-"+id);
  if(!el) return;
  if(el.classList.contains("open")){el.classList.remove("open");if(chev)chev.textContent="▶";}
  else{el.classList.add("open");if(chev)chev.textContent="▼";}
}

function qRenderWelcome(){
  const gs=qGlobalStats();
  const pct=gs.total?Math.round(gs.ok/gs.total*100):0;
  let h=`<h3>✏️ Práctica por Área · 180 Preguntas</h3>
    <p>Preguntas organizadas por subárea y tema oficial del ACREDITA-BACH 2026. Selecciona un área para comenzar.</p>
    <div class="qw-stats">
      <div class="qw-stat"><span class="qw-stat-n" style="color:var(--accent)">${gs.answered}</span><span class="qw-stat-l">Respondidas</span></div>
      <div class="qw-stat"><span class="qw-stat-n" style="color:var(--green)">${gs.ok}</span><span class="qw-stat-l">Correctas</span></div>
      <div class="qw-stat"><span class="qw-stat-n" style="color:var(--red)">${gs.err}</span><span class="qw-stat-l">Incorrectas</span></div>
      <div class="qw-stat"><span class="qw-stat-n" style="color:var(--gold)">${pct}%</span><span class="qw-stat-l">Aciertos</span></div>
    </div>
    <div class="qw-areas">`;
  AREAS_QUIZ.forEach(a=>{
    const st=qAreaStats(a);
    const p=st.total?Math.round(st.answered/st.total*100):0;
    const pok=st.total?Math.round(st.ok/st.total*100):0;
    h+=`<div class="qw-area-card" style="border-left-color:${a.color}" onclick="qGoQuiz(${a.id},null)">
      <div class="qw-area-num">Área ${a.id} · ${st.total} reactivos</div>
      <div class="qw-area-name">${a.nombre}</div>
      <div class="qw-mini-bar"><div class="qw-mini-fill" style="width:${p}%;background:${a.color}"></div></div>
      <div class="qw-mini-meta"><span>${st.answered}/${st.total}</span><span>${pok}% ✓</span></div>
    </div>`;
  });
  h+=`</div>`;
  if(gs.answered>0) h+=`<button class="btn-qreset" onclick="qResetAll()">↺ Reiniciar todo el quiz</button>`;
  const wel=document.getElementById('quiz-screen-welcome');
  if(wel){wel.innerHTML=h;wel.classList.remove('hidden');}
  const det=document.getElementById('quiz-screen-detail');
  if(det) det.classList.add('hidden');
  const fin=document.getElementById('quiz-screen-final');
  if(fin) fin.classList.add('hidden');
}

function qRenderDetail(){
  const area=AREAS_QUIZ.find(a=>a.id===qState.areaId);
  if(!area) return;
  const subsToShow=qState.subId?area.subs.filter(s=>s.id===qState.subId):area.subs;
  const st=qAreaStats(area);
  let h=`<div class="qs-area-title" style="color:${area.color}">Área ${area.id}: ${area.nombre}</div>
    <div class="qs-area-sub">${st.answered}/${st.total} respondidas · ${st.ok} correctas · ${st.err} incorrectas</div>`;
  subsToShow.forEach(sub=>{
    const ss=qSubStats(sub);
    h+=`<div class="qs-sub-block">
      <div class="qs-sub-heading">
        <span class="qs-sub-label">${sub.id} ${sub.nombre}</span>
        <span class="qs-sub-count">${ss.ok}/${ss.total}</span>
      </div>`;
    sub.temas.forEach(t=>{
      const ans=qState.answers[t.id];
      const answered=ans!==undefined;
      const isOk=answered&&ans===t.c;
      h+=`<div class="qs-q-card ${answered?(isOk?"qs-ok":"qs-err"):""}" id="qs-qc-${t.id}">
        <div class="qs-q-head">
          <span class="qs-q-tag">${t.id}</span>
          <div class="qs-q-text">${t.pregunta.replace(/\n/g,"<br>")}</div>
        </div>
        <div class="qs-q-opts">`;
      t.opts.forEach((op,oi)=>{
        let cls="";
        if(answered){
          if(oi===t.c&&oi===ans)cls="qs-s-ok";
          else if(oi===ans&&oi!==t.c)cls="qs-s-err";
          else if(oi===t.c)cls="qs-s-reveal";
        }
        h+=`<button class="qs-opt ${cls}" ${answered?"disabled":""} onclick="qAnswer('${t.id}',${oi},${t.c},${area.id},'${sub.id}')">
          <span class="qs-opt-letter">${String.fromCharCode(65+oi)}</span>
          <span>${op}</span>
        </button>`;
      });
      h+=`</div>`;
      if(answered){
        const cls2=isOk?"qs-ok":"qs-err";
        const label=isOk?"✓ Correcto":"✗ Incorrecto — respuesta: ("+String.fromCharCode(65+t.c)+")";
        h+=`<div class="qs-exp ${cls2}"><strong>${label}:</strong> ${t.exp}</div>`;
      }
      h+=`</div>`;
    });
    h+=`</div>`;
  });
  const det=document.getElementById('quiz-screen-detail');
  if(det){det.innerHTML=h;det.classList.remove('hidden');}
  const wel=document.getElementById('quiz-screen-welcome');
  if(wel) wel.classList.add('hidden');
  const fin=document.getElementById('quiz-screen-final');
  if(fin) fin.classList.add('hidden');
}

function qAnswer(tid,oi,correcta,areaId,subId){
  qState.answers[tid]=oi;
  qSaveAnswers();
  if(oi===correcta){quizScore+=10;quizStreak++;}else{quizStreak=0;}
  qState.areaId=areaId;qState.subId=subId;qState.screen="quiz";
  qUpdate();
  setTimeout(()=>{
    const el=document.getElementById("qs-qc-"+tid);
    if(el) el.scrollIntoView({behavior:"smooth",block:"nearest"});
  },50);
}

function qRenderFinal(){
  const gs=qGlobalStats();
  const pct=gs.total?Math.round(gs.ok/gs.total*100):0;
  const msg=pct>=80?"¡Excelente! Estás muy bien preparado.":pct>=60?"Buen avance. Repasa las áreas con más errores.":"Sigue practicando. Revisa cada área con cuidado.";
  let h=`<div class="qfinal-pct">${pct}%</div>
    <div class="qfinal-sub">${gs.ok} de ${gs.total} correctas · ${msg}</div>
    <button class="btn-primary" onclick="qShowWelcome()">← Volver</button>
    <button class="btn-primary" style="background:var(--red);margin-left:8px" onclick="qResetAll()">Reiniciar</button>
    <table class="qfinal-table">
      <tr><th>Área</th><th>Resp.</th><th>✓</th><th>%</th><th>Progreso</th></tr>`;
  AREAS_QUIZ.forEach(a=>{
    const st=qAreaStats(a);
    const p=st.total?Math.round(st.ok/st.total*100):0;
    const p2=st.total?Math.round(st.answered/st.total*100):0;
    h+=`<tr>
      <td style="color:${a.color};font-weight:600;font-size:0.8rem">${a.nombre}</td>
      <td style="font-family:monospace">${st.answered}/${st.total}</td>
      <td style="color:var(--green);font-family:monospace">${st.ok}</td>
      <td style="font-family:monospace">${p}%</td>
      <td><div class="qfinal-bar"><div class="qfinal-bar-f" style="width:${p2}%;background:${a.color}"></div></div></td>
    </tr>`;
  });
  h+=`</table>`;
  const fin=document.getElementById('quiz-screen-final');
  if(fin){fin.innerHTML=h;fin.classList.remove('hidden');}
  const wel=document.getElementById('quiz-screen-welcome');
  if(wel) wel.classList.add('hidden');
  const det=document.getElementById('quiz-screen-detail');
  if(det) det.classList.add('hidden');
}

function qShowWelcome(){qState.screen="welcome";qState.areaId=null;qState.subId=null;qUpdate();}
function qGoQuiz(areaId,subId){
  qState.screen="quiz";qState.areaId=areaId;
  qState.subId=subId||(AREAS_QUIZ.find(a=>a.id===areaId)?.subs[0]?.id||null);
  qUpdate();
  const el=document.getElementById("qsbsub-"+areaId);
  if(el&&!el.classList.contains("open")){el.classList.add("open");const chev=document.getElementById("qchev-"+areaId);if(chev)chev.textContent="▼";}
}
function qResetAll(){
  if(!confirm("¿Reiniciar todas las respuestas del quiz?")) return;
  qState.answers={};qSaveAnswers();quizScore=0;quizStreak=0;
  qState.screen="welcome";qUpdate();
}


