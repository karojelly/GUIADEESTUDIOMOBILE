// ============================================================
//  MOBILE AREA BAR  (horizontal scroll pills above quiz)
// ============================================================
function buildAreaBar() {
  const bar = document.getElementById('quiz-area-bar');
  if (!bar) return;
  const areaColors = ['#ffe600','#bf5fff','#ff2d78','#ff9f0a','#00fff0','#ff2d78','#bf5fff'];
  let h = `<div class="qab-pill ${!qState.areaId?'active':''}" onclick="qShowWelcome()">⌂ Resumen</div>`;
  AREAS_QUIZ.forEach((a,i) => {
    const st = qAreaStats(a);
    const active = qState.screen==='quiz' && qState.areaId===a.id;
    const pct = st.total ? Math.round(st.ok/st.total*100) : 0;
    h += `<div class="qab-pill ${active?'active':''}"
      style="${active?'border-color:'+a.color+';color:'+a.color+';background:'+a.color+'18':''}"
      onclick="qGoQuiz(${a.id},null)">
      <span style="width:7px;height:7px;border-radius:50%;background:${a.color};flex-shrink:0;display:inline-block"></span>
      Área ${a.id} · ${pct}%
    </div>`;
  });
  bar.innerHTML = h;
  // scroll active pill into view
  const active = bar.querySelector('.qab-pill.active');
  if (active) active.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
}

document.addEventListener('DOMContentLoaded', () => {
  showTema(1);
  loadFlashcards();
  renderPlan();
  revealElements();
  qUpdate();
  buildAreaBar();
});
