<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0010">
<title>ACREDITA-BACH 2026 | Guía de Estudio Interactiva</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════════
   iPhone XR — 414 × 896 pt  (safe-area aware)
   Cyberpunk palette: yellow / pink / purple neon
   ══════════════════════════════════════════════ */

:root {
  --navy: #0a0010;
  --blue: #1a0028;
  --accent: #ffe600;
  --gold:   #ffe600;
  --green:  #00fff0;
  --red:    #ff2d78;
  --card:   #140020;
  --border: rgba(255,230,0,.18);
  --text:   #d8b8ff;
  --cyber-pink:   #ff2d78;
  --cyber-purple: #bf5fff;
  --cyber-yellow: #ffe600;
  --cyber-cyan:   #00fff0;

  /* iOS safe-area */
  --sat: env(safe-area-inset-top,    44px);
  --sab: env(safe-area-inset-bottom, 34px);

  /* Bottom tab bar */
  --tab-h: 56px;
  --tab-total: calc(var(--tab-h) + var(--sab));
}

/* ── Reset ───────────────────────────────────── */
*, *::before, *::after {
  box-sizing: border-box; margin: 0; padding: 0;
  -webkit-tap-highlight-color: transparent;
}
html { height: 100%; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--navy); color: var(--text);
  min-height: 100dvh;
  overflow-x: hidden;
  /* Reserve space for fixed bottom nav */
  padding-bottom: var(--tab-total);
}

/* ── Cyberpunk grid bg ───────────────────────── */
body::before {
  content: ''; position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(255,230,0,.04)  1px, transparent 1px),
    linear-gradient(90deg, rgba(191,95,255,.04) 1px, transparent 1px);
  background-size: 32px 32px;
}

/* ══════════════════════════════════════════════
   TOP HEADER  (sticky, respects notch)
   ══════════════════════════════════════════════ */
header {
  position: sticky; top: 0; z-index: 200;
  background: rgba(5,0,8,.97);
  border-bottom: 1px solid var(--border);
  padding: calc(var(--sat) + 8px) 16px 10px;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}
.header-inner {
  display: flex; align-items: center;
  justify-content: space-between; gap: 10px;
}
.logo { display: flex; align-items: center; gap: 10px; }
.logo-icon {
  width: 38px; height: 38px; flex-shrink: 0;
  background: linear-gradient(135deg, var(--cyber-yellow), var(--cyber-pink));
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; font-weight: 800; color: #0a0010;
  font-family: 'Syne', sans-serif;
  box-shadow: 0 0 18px rgba(255,230,0,.5), 0 0 36px rgba(255,45,120,.2);
}
.logo-text h1 {
  font-family: 'Syne', sans-serif;
  font-size: .92rem; font-weight: 800; color: #fff; line-height: 1.2;
}
.logo-text p {
  font-size: .58rem; color: var(--accent);
  font-family: 'DM Mono', monospace; letter-spacing: .08em;
}
/* Compact score pill replaces wide stat chips */
.header-score {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,230,0,.07);
  border: 1px solid rgba(255,230,0,.22);
  border-radius: 20px; padding: 5px 11px;
  font-family: 'DM Mono', monospace;
  font-size: .7rem; color: var(--cyber-yellow);
  white-space: nowrap; flex-shrink: 0;
}
.header-score strong { font-weight: 700; }
.header-stats { display: none; }   /* desktop chips hidden */

/* ══════════════════════════════════════════════
   BOTTOM TAB BAR  (iOS-style)
   ══════════════════════════════════════════════ */
.nav-tabs {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 300;
  background: rgba(6,0,12,.97);
  border-top: 1px solid rgba(255,230,0,.15);
  display: flex; align-items: stretch;
  height: var(--tab-total);
  padding-bottom: var(--sab);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}
.tab-btn {
  flex: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 3px;
  background: none; border: none; cursor: pointer;
  color: rgba(180,150,220,.5);
  font-family: 'DM Sans', sans-serif;
  font-size: .55rem; font-weight: 500;
  letter-spacing: .02em;
  padding: 6px 2px 2px;
  transition: color .15s;
  -webkit-appearance: none;
}
.tab-btn .tb-icon { font-size: 1.3rem; line-height: 1; }
.tab-btn .tb-label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 52px; }
.tab-btn.active {
  color: var(--cyber-yellow);
  text-shadow: 0 0 8px rgba(255,230,0,.55);
}
.tab-btn.active .tb-icon {
  filter: drop-shadow(0 0 5px rgba(255,230,0,.6));
}

/* ══════════════════════════════════════════════
   MAIN / PANELS
   ══════════════════════════════════════════════ */
.main { position: relative; z-index: 1; padding: 14px 14px 24px; }
.panel { display: none; }
.panel.active { display: block; }

/* ── Shared elements ─────────────────────────── */
.section-title {
  font-family: 'Syne', sans-serif;
  font-size: 1rem; font-weight: 700;
  color: var(--cyber-yellow); margin-bottom: 12px;
  display: flex; align-items: center; gap: 8px;
  text-shadow: 0 0 10px rgba(255,230,0,.3);
}
.section-title::after {
  content: ''; flex: 1; height: 1px;
  background: linear-gradient(90deg, rgba(255,230,0,.3), transparent);
}

.btn-primary {
  background: linear-gradient(135deg, var(--cyber-yellow), var(--cyber-pink));
  color: #0a0010; border: none; border-radius: 12px;
  padding: 13px 18px; width: 100%;
  font-family: 'DM Sans', sans-serif; font-size: .9rem; font-weight: 700;
  cursor: pointer; -webkit-appearance: none;
  box-shadow: 0 4px 18px rgba(255,230,0,.28);
  transition: transform .12s;
  min-height: 48px;   /* iOS touch target */
}
.btn-primary:active { transform: scale(.97); }

.btn-outline {
  background: transparent;
  color: var(--cyber-purple); border: 1px solid var(--cyber-purple);
  border-radius: 12px; padding: 11px 16px; width: 100%;
  font-family: 'DM Sans', sans-serif; font-size: .88rem; font-weight: 600;
  cursor: pointer; -webkit-appearance: none; min-height: 44px;
  transition: background .12s;
}
.btn-outline:active { background: rgba(191,95,255,.12); }

/* ── Reveal animation ────────────────────────── */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity .3s, transform .3s; }
.reveal.visible { opacity: 1; transform: none; }

/* ══════════════════════════════════════════════
   DASHBOARD
   ══════════════════════════════════════════════ */
.hero-banner {
  background: linear-gradient(135deg, #1a0030 0%, #0a0010 60%, #050008 100%);
  border: 1px solid var(--border); border-radius: 16px;
  padding: 18px 16px; margin-bottom: 16px;
  position: relative; overflow: hidden;
}
.hero-banner::after {
  content: 'ACREDITA';
  position: absolute; right: -16px; top: 50%;
  transform: translateY(-50%) rotate(-8deg);
  font-family: 'Syne', sans-serif; font-size: 3.2rem; font-weight: 800;
  color: rgba(255,255,255,.025); white-space: nowrap; pointer-events: none;
}
.hero-banner h2 {
  font-family: 'Syne', sans-serif;
  font-size: 1.2rem; font-weight: 800; color: #fff;
  margin-bottom: 6px; line-height: 1.3;
}
.hero-banner p { font-size: .82rem; color: var(--text); line-height: 1.55; }
.hero-actions {
  margin-top: 14px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
}
.hero-actions .btn-primary { grid-column: 1 / -1; }

/* ── Area cards ──────────────────────────────── */
.areas-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 9px; margin-bottom: 16px;
}
.area-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 12px 12px 15px;
  cursor: pointer; position: relative; overflow: hidden;
  transition: transform .15s;
}
.area-card::before {
  content: ''; position: absolute; top: 0; left: 0;
  width: 3px; height: 100%;
  background: var(--area-color, var(--cyber-yellow));
  box-shadow: 0 0 6px var(--area-color, var(--cyber-yellow));
}
.area-card:active { transform: scale(.97); }
.area-num {
  font-family: 'DM Mono', monospace; font-size: .6rem;
  color: var(--area-color, var(--accent));
  text-transform: uppercase; letter-spacing: .1em; margin-bottom: 4px;
}
.area-name {
  font-family: 'Syne', sans-serif; font-size: .82rem; font-weight: 700;
  color: #fff; margin-bottom: 5px; line-height: 1.25;
}
.area-meta { display: flex; gap: 4px; flex-wrap: wrap; }
.area-meta span {
  background: rgba(255,255,255,.05); padding: 2px 6px;
  border-radius: 20px; font-size: .6rem; color: var(--text);
}
.progress-bar { margin-top: 7px; height: 3px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--area-color, var(--accent)); border-radius: 3px; width: 0%; }

/* area color tokens */
[data-area="1"] { --area-color: #ffe600; }
[data-area="2"] { --area-color: #bf5fff; }
[data-area="3"] { --area-color: #ff2d78; }
[data-area="4"] { --area-color: #ff9f0a; }
[data-area="5"] { --area-color: #00fff0; }
[data-area="6"] { --area-color: #ff2d78; }
[data-area="7"] { --area-color: #bf5fff; }

/* ══════════════════════════════════════════════
   TEORÍA  — horiz scroll area selector
   ══════════════════════════════════════════════ */
.teoria-grid { display: flex; flex-direction: column; gap: 12px; }

.teoria-sidebar {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 10px 12px;
}
.teoria-sidebar h3 {
  font-family: 'Syne', sans-serif; font-size: .7rem; font-weight: 700;
  color: var(--cyber-yellow); text-transform: uppercase;
  letter-spacing: .1em; margin-bottom: 8px;
}
/* Horizontal scroll strip */
.teoria-scroll {
  display: flex; gap: 6px; overflow-x: auto;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
  padding-bottom: 2px;
}
.teoria-scroll::-webkit-scrollbar { display: none; }
.teoria-link {
  display: inline-block; white-space: nowrap; flex-shrink: 0;
  padding: 6px 13px; border-radius: 20px;
  border: 1px solid transparent; font-size: .75rem; color: var(--text);
  cursor: pointer; transition: all .15s;
}
.teoria-link.active {
  background: rgba(255,230,0,.1); color: var(--cyber-yellow);
  border-color: rgba(255,230,0,.25);
}

.teoria-content {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 12px; padding: 16px;
}
.teoria-content h2 {
  font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 800; color: #fff;
  margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid var(--border);
}
.teoria-content h3 {
  font-family: 'Syne', sans-serif; font-size: .88rem; font-weight: 700;
  color: var(--cyber-purple); margin: 14px 0 6px;
  display: flex; align-items: center; gap: 5px;
}
.teoria-content h3::before { content: '▶'; font-size: .5rem; }
.teoria-content p { font-size: .83rem; line-height: 1.65; color: var(--text); margin-bottom: 8px; }
.teoria-content ul { list-style: none; margin: 4px 0 10px; }
.teoria-content ul li { font-size: .82rem; color: var(--text); padding: 3px 0 3px 16px; position: relative; line-height: 1.5; }
.teoria-content ul li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: .68rem; }

.concept-box {
  background: rgba(191,95,255,.07); border: 1px solid rgba(191,95,255,.2);
  border-radius: 10px; padding: 10px 12px; margin: 8px 0;
  font-size: .82rem; color: var(--text); line-height: 1.55;
}
.concept-box strong { color: #fff; }

.formula-box {
  background: rgba(255,230,0,.07); border: 1px solid rgba(255,230,0,.22);
  border-radius: 10px; padding: 8px 12px; font-family: 'DM Mono', monospace;
  font-size: .78rem; color: var(--cyber-yellow); margin: 8px 0; text-align: center;
  text-shadow: 0 0 8px rgba(255,230,0,.4); overflow-x: auto;
}

.table-wrap { overflow-x: auto; margin: 10px 0; -webkit-overflow-scrolling: touch; }
table { width: 100%; border-collapse: collapse; font-size: .78rem; }
th {
  background: rgba(255,230,0,.08); color: var(--cyber-yellow);
  font-family: 'Syne', sans-serif; font-size: .68rem; text-transform: uppercase;
  letter-spacing: .06em; padding: 8px 10px; text-align: left;
}
td { padding: 7px 10px; border-bottom: 1px solid var(--border); color: var(--text); }

/* más info */
.mas-info-btn {
  display: inline-flex; align-items: center; gap: 5px;
  background: linear-gradient(135deg, rgba(191,95,255,.12), rgba(255,45,120,.08));
  border: 1px solid rgba(191,95,255,.35); border-radius: 20px;
  padding: 5px 12px; font-size: .71rem; font-family: 'DM Mono', monospace;
  color: var(--cyber-purple); cursor: pointer;
  margin: 5px 0 10px; -webkit-appearance: none; min-height: 34px;
}
.mas-info-btn:active { background: rgba(191,95,255,.2); }
.mas-info-panel {
  background: linear-gradient(135deg, rgba(10,0,16,.9), rgba(26,0,40,.5));
  border: 1px solid rgba(191,95,255,.25);
  border-radius: 12px; padding: 14px; margin: 4px 0 14px; display: none;
}
.mas-info-panel.open { display: block; }
.mas-info-panel .mi-title {
  font-family: 'Syne', sans-serif; font-size: .78rem; font-weight: 700;
  color: var(--cyber-purple); text-transform: uppercase; letter-spacing: .08em;
  margin-bottom: 10px; display: flex; align-items: center; gap: 5px;
}
.mas-info-panel h4 { font-family: 'Syne', sans-serif; font-size: .88rem; font-weight: 700; color: var(--cyber-pink); margin: 10px 0 5px; }
.mas-info-panel p { font-size: .82rem; color: var(--text); line-height: 1.6; margin-bottom: 5px; }
.mi-example { background: rgba(245,166,35,.07); border-left: 3px solid var(--gold); border-radius: 0 8px 8px 0; padding: 8px 10px; margin: 5px 0; font-size: .8rem; color: #fde68a; line-height: 1.55; }
.mi-step { display: flex; gap: 8px; align-items: flex-start; background: rgba(79,142,247,.06); border: 1px solid rgba(79,142,247,.15); border-radius: 8px; padding: 8px 10px; margin: 4px 0; font-size: .8rem; line-height: 1.55; }
.mi-step-num { min-width: 22px; height: 22px; background: var(--accent); color: #0a0010; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .68rem; font-weight: 700; font-family: 'DM Mono', monospace; flex-shrink: 0; }
.mi-formula { background: rgba(255,230,0,.07); border: 1px solid rgba(255,230,0,.2); border-radius: 8px; padding: 6px 10px; font-family: 'DM Mono', monospace; font-size: .78rem; color: var(--cyber-yellow); margin: 5px 0; text-align: center; overflow-x: auto; }
.error-box { background: rgba(255,45,120,.08); border: 1px solid rgba(255,45,120,.25); border-radius: 10px; padding: 10px 12px; font-size: .83rem; color: var(--cyber-pink); }

/* ══════════════════════════════════════════════
   QUIZ 180 — mobile layout (no sidebar)
   ══════════════════════════════════════════════ */
#quiz-inner-wrapper { position: relative; }

/* thin neon progress bar at top */
#qprogress-bar-wrap { height: 3px; background: rgba(255,230,0,.1); }
#qprogress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--cyber-yellow), var(--cyber-pink));
  box-shadow: 0 0 6px var(--cyber-yellow);
  transition: width .4s; width: 0%;
}

/* full-width, no sidebar */
#quiz-split { display: flex; flex-direction: column; }
#quiz-sidebar { display: none; }    /* sidebar hidden */

/* ── Mobile quiz top bar (score + streak) ── */
#quiz-topbar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 14px; background: rgba(255,230,0,.03);
  border-bottom: 1px solid rgba(255,230,0,.08);
  font-size: .72rem;
}
#qsb-pts {
  color: var(--cyber-yellow); font-family: 'DM Mono', monospace;
  font-weight: 700; text-shadow: 0 0 6px rgba(255,230,0,.45);
}
#qsb-streak { color: var(--text); }

/* ── Area picker: horizontal scroll pills ── */
#quiz-area-bar {
  display: flex; gap: 6px; overflow-x: auto;
  -webkit-overflow-scrolling: touch; scrollbar-width: none;
  padding: 10px 14px 8px;
  border-bottom: 1px solid rgba(255,230,0,.08);
}
#quiz-area-bar::-webkit-scrollbar { display: none; }
.qab-pill {
  display: inline-flex; align-items: center; gap: 5px;
  white-space: nowrap; flex-shrink: 0;
  padding: 6px 12px; border-radius: 20px;
  font-size: .72rem; font-family: 'DM Mono', monospace;
  border: 1px solid rgba(255,230,0,.18);
  background: rgba(255,230,0,.03); color: var(--text);
  cursor: pointer; transition: all .15s; min-height: 34px;
}
.qab-pill.active {
  background: rgba(255,230,0,.12);
  border-color: var(--cyber-yellow);
  color: var(--cyber-yellow); font-weight: 700;
}

#quiz-content-area { padding: 12px 14px 20px; }

/* ── Quiz welcome ── */
#quiz-screen-welcome h3 {
  font-family: 'Syne', sans-serif; font-size: 1.05rem; font-weight: 700;
  color: #fff; margin-bottom: 4px;
}
#quiz-screen-welcome > p { font-size: .82rem; color: var(--text); margin-bottom: 14px; line-height: 1.55; }
.qw-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
.qw-stat {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px 12px; text-align: center;
}
.qw-stat-n { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 700; color: var(--cyber-yellow); line-height: 1; display: block; }
.qw-stat-l { font-size: .62rem; color: var(--text); text-transform: uppercase; letter-spacing: .06em; margin-top: 3px; display: block; }
.qw-areas { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.qw-area-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px 12px;
  cursor: pointer; border-left: 3px solid transparent; transition: transform .15s;
}
.qw-area-card:active { transform: scale(.97); }
.qw-area-num { font-family: 'DM Mono', monospace; font-size: .62rem; color: rgba(180,150,220,.6); margin-bottom: 3px; }
.qw-area-name { font-size: .78rem; font-weight: 600; color: #fff; margin-bottom: 5px; line-height: 1.25; }
.qw-mini-bar { height: 3px; background: rgba(255,255,255,.07); border-radius: 2px; overflow: hidden; }
.qw-mini-fill { height: 100%; border-radius: 2px; }
.qw-mini-meta { display: flex; justify-content: space-between; margin-top: 4px; font-size: .62rem; color: rgba(180,150,220,.6); font-family: 'DM Mono', monospace; }
.btn-qreset {
  padding: 11px 18px; border: 1px solid rgba(255,45,120,.35);
  border-radius: 10px; background: transparent; color: var(--red);
  cursor: pointer; font-family: 'DM Sans', sans-serif; font-size: .85rem;
  margin-top: 12px; width: 100%; -webkit-appearance: none; min-height: 44px;
}

/* ── Sub-area heading ── */
.qs-area-title { font-family: 'Syne', sans-serif; font-size: .95rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
.qs-area-sub { font-size: .7rem; color: rgba(180,150,220,.6); margin-bottom: 12px; font-family: 'DM Mono', monospace; }
.qs-sub-block { margin-bottom: 20px; }
.qs-sub-heading {
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border);
}
.qs-sub-label { font-size: .82rem; font-weight: 600; color: var(--cyber-yellow); flex: 1; line-height: 1.3; }
.qs-sub-count { font-size: .65rem; color: rgba(180,150,220,.6); font-family: 'DM Mono', monospace; white-space: nowrap; }

/* ── Question card ── */
.qs-q-card {
  background: rgba(20,0,32,.8); border: 1px solid var(--border);
  border-radius: 12px; margin-bottom: 10px; overflow: hidden;
  transition: border-color .2s;
}
.qs-q-card.qs-ok  { border-color: rgba(0,255,240,.45); }
.qs-q-card.qs-err { border-color: rgba(255,45,120,.4); }
.qs-q-head { padding: 12px 12px 0; display: flex; gap: 8px; align-items: flex-start; }
.qs-q-tag {
  font-family: 'DM Mono', monospace; font-size: .6rem;
  background: rgba(255,230,0,.08); border: 1px solid rgba(255,230,0,.2);
  border-radius: 4px; padding: 2px 6px; white-space: nowrap;
  flex-shrink: 0; margin-top: 1px; color: var(--cyber-yellow);
}
.qs-q-text { font-size: .87rem; line-height: 1.55; color: #fff; flex: 1; padding-bottom: 10px; }
.qs-q-opts { padding: 0 12px 10px; display: flex; flex-direction: column; gap: 7px; }
.qs-opt {
  display: flex; align-items: flex-start; gap: 9px;
  padding: 12px 12px; border-radius: 10px;
  border: 1px solid var(--border); background: rgba(255,255,255,.025);
  cursor: pointer; font-size: .86rem; line-height: 1.4;
  color: var(--text); text-align: left; width: 100%;
  font-family: 'DM Sans', sans-serif; -webkit-appearance: none;
  min-height: 48px;   /* comfortable touch target */
  transition: all .12s;
}
.qs-opt:active:not(:disabled) {
  background: rgba(255,230,0,.07); border-color: var(--cyber-yellow); color: var(--cyber-yellow);
}
.qs-opt:disabled { cursor: default; }
.qs-opt-letter {
  width: 24px; height: 24px; min-width: 24px;
  background: rgba(255,230,0,.1); border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Mono', monospace; font-size: .72rem; font-weight: 700;
  color: var(--cyber-yellow); flex-shrink: 0;
}
.qs-opt.qs-s-ok  { background: rgba(0,255,240,.1);  border-color: var(--cyber-cyan); color: var(--cyber-cyan); }
.qs-opt.qs-s-ok  .qs-opt-letter { background: rgba(0,255,240,.15); color: var(--cyber-cyan); }
.qs-opt.qs-s-err { background: rgba(255,45,120,.1); border-color: var(--cyber-pink); color: var(--cyber-pink); }
.qs-opt.qs-s-err .qs-opt-letter { background: rgba(255,45,120,.15); color: var(--cyber-pink); }
.qs-opt.qs-s-reveal { background: rgba(0,255,240,.06); border-color: rgba(0,255,240,.3); color: var(--cyber-cyan); }
.qs-exp { margin: 0 12px 10px; padding: 10px 12px; border-radius: 8px; font-size: .81rem; line-height: 1.5; }
.qs-exp.qs-ok  { background: rgba(0,255,240,.07);  color: var(--cyber-cyan); border-left: 3px solid var(--cyber-cyan); }
.qs-exp.qs-err { background: rgba(255,45,120,.08); color: var(--cyber-pink); border-left: 3px solid var(--cyber-pink); }

/* ── Final screen ── */
#quiz-screen-final { padding: 10px 0 20px; }
.qfinal-pct { font-family: 'Syne', sans-serif; font-size: 4rem; font-weight: 800; color: var(--cyber-yellow); line-height: 1; text-shadow: 0 0 24px rgba(255,230,0,.5); }
.qfinal-sub { font-size: .84rem; color: var(--text); margin: 6px 0 16px; line-height: 1.5; }
.qfinal-table { width: 100%; border-collapse: collapse; font-size: .76rem; margin-top: 8px; }
.qfinal-table th { text-align: left; padding: 7px 8px; border-bottom: 1px solid var(--border); font-size: .63rem; color: rgba(180,150,220,.6); font-weight: 500; text-transform: uppercase; letter-spacing: .04em; }
.qfinal-table td { padding: 7px 8px; border-bottom: 1px solid rgba(255,230,0,.06); font-size: .73rem; }
.qfinal-bar { height: 4px; background: rgba(255,255,255,.07); border-radius: 3px; overflow: hidden; min-width: 44px; }
.qfinal-bar-f { height: 100%; border-radius: 3px; }

/* ── Legacy score display (unused on mobile) ── */
.score-display { display: none; }
.qsb-home, #qsb-areas, .qsb-area-head, .qsb-subs, .qsb-sub-item { display: none; }

/* ══════════════════════════════════════════════
   FLASHCARDS
   ══════════════════════════════════════════════ */
.flashcard-area { max-width: 100%; }
.fc-header-row {
  display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px;
}
#fc-area-select {
  background: var(--card); border: 1px solid var(--border);
  color: #fff; border-radius: 10px; padding: 10px 14px;
  font-family: 'DM Sans', sans-serif; font-size: .88rem;
  cursor: pointer; -webkit-appearance: none; width: 100%;
}
.flashcard {
  perspective: 1000px; height: 210px;
  cursor: pointer; margin-bottom: 14px;
}
.flashcard-inner {
  position: relative; width: 100%; height: 100%;
  transform-style: preserve-3d;
  transition: transform .42s cubic-bezier(.4,0,.2,1);
}
.flashcard.flipped .flashcard-inner { transform: rotateY(180deg); }
.flashcard-front, .flashcard-back {
  position: absolute; inset: 0;
  backface-visibility: hidden; -webkit-backface-visibility: hidden;
  border-radius: 14px; padding: 20px;
  display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
}
.flashcard-front { background: linear-gradient(135deg,#1a0030,#0d0018); border: 1px solid var(--border); }
.flashcard-back  { background: linear-gradient(135deg,#001a30,#00080f); border: 1px solid rgba(0,255,240,.3); transform: rotateY(180deg); }
.flashcard-label { font-family: 'DM Mono', monospace; font-size: .62rem; text-transform: uppercase; letter-spacing: .14em; margin-bottom: 10px; opacity: .6; }
.flashcard-front .flashcard-label { color: var(--accent); }
.flashcard-back  .flashcard-label { color: var(--cyber-cyan); }
.flashcard-text  { font-family: 'Syne', sans-serif; font-size: .98rem; font-weight: 700; color: #fff; line-height: 1.45; }
.flashcard-hint  { margin-top: 10px; font-size: .67rem; color: rgba(255,255,255,.32); }
.flashcard-nav   { display: flex; justify-content: center; gap: 10px; align-items: center; }
.flashcard-nav .btn-outline  { width: auto; padding: 10px 20px; }
.flashcard-nav .btn-primary  { width: auto; padding: 12px 22px; }
.fc-counter { font-family: 'DM Mono', monospace; font-size: .8rem; color: var(--text); background: rgba(255,230,0,.08); padding: 5px 14px; border-radius: 20px; }

/* ══════════════════════════════════════════════
   PLAN DE ESTUDIO
   ══════════════════════════════════════════════ */
.plan-grid { display: flex; flex-direction: column; gap: 8px; }
.day-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 12px 14px; }
.day-card.today { border-color: var(--cyber-yellow); box-shadow: 0 0 14px rgba(255,230,0,.14); }
.today-badge { display: inline-block; background: var(--cyber-yellow); color: #0a0010; border-radius: 20px; padding: 2px 10px; font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 6px; }
.day-label { font-family: 'DM Mono', monospace; font-size: .67rem; color: var(--accent); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 3px; }
.day-card.today .day-label { color: var(--cyber-yellow); }
.day-area   { font-family: 'Syne', sans-serif; font-size: .88rem; font-weight: 700; color: #fff; margin-bottom: 3px; }
.day-topics { font-size: .78rem; color: var(--text); line-height: 1.5; }

/* ══════════════════════════════════════════════
   INFO EXAMEN
   ══════════════════════════════════════════════ */
.info-grid { display: flex; flex-direction: column; gap: 10px; }
.info-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px; }
.info-card-icon { font-size: 1.6rem; margin-bottom: 8px; }
.info-card h3  { font-family: 'Syne', sans-serif; font-size: .92rem; font-weight: 700; color: var(--cyber-yellow); margin-bottom: 6px; }
.info-card p, .info-card li { font-size: .82rem; color: var(--text); line-height: 1.6; }
.info-card ul { list-style: none; }
.info-card ul li { padding: 2px 0 2px 14px; position: relative; }
.info-card ul li::before { content: '✓'; position: absolute; left: 0; color: var(--cyber-cyan); font-size: .7rem; }
.session-table th, .session-table td { font-size: .74rem; padding: 6px 8px; }

/* ══════════════════════════════════════════════
   MISC UTILITIES
   ══════════════════════════════════════════════ */
.ai-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: linear-gradient(135deg,rgba(191,95,255,.15),rgba(255,45,120,.1));
  border: 1px solid rgba(191,95,255,.3); border-radius: 20px;
  padding: 3px 10px; font-size: .67rem; font-family: 'DM Mono', monospace; color: var(--cyber-purple);
}
.ai-dot { width: 5px; height: 5px; background: var(--cyber-pink); border-radius: 50%; animation: pulse 1.5s infinite; box-shadow: 0 0 5px var(--cyber-pink); }
@keyframes pulse  { 0%,100%{opacity:1} 50%{opacity:.4} }
@keyframes spin   { to{ transform:rotate(360deg) } }
.hidden { display: none !important; }
.empty-state { text-align: center; padding: 3rem 1rem; color: var(--text); font-size: .88rem; }
.empty-state .big-icon { font-size: 2.4rem; margin-bottom: 10px; }
select, input {
  background: var(--card); border: 1px solid var(--border);
  color: #fff; border-radius: 10px; padding: 10px 12px;
  font-family: 'DM Sans', sans-serif; font-size: .88rem;
  -webkit-appearance: none; width: 100%;
}
select:focus, input:focus { outline: none; border-color: var(--accent); }
</style>
