let currentQuizArea = 0;
let quizScore = 0;
let quizStreak = 0;
let currentTeoria = 1;
let fcData = [];
let fcIndex = 0;
let fcFlipped = false;
let questionAnswered = false;
let currentQuestion = null;
// Quiz offline state
let quizBancoActual = [];
let quizIndexActual = 0;
let usedIndexes = new Set();

// ============================================================
//  MÁS INFORMACIÓN — OFFLINE (contenido estático)
// ============================================================
function toggleMasInfo(btn, key) {
  const panel = btn.nextElementSibling;
  const isOpen = panel.classList.contains('open');

  if (isOpen) {
    panel.classList.remove('open');
    btn.textContent = btn.textContent.replace('▲ Ocultar información', '✨ ' + btn.textContent.split('·')[1].trim());
    btn.textContent = '✨ Más información · ' + key;
    return;
  }

  // Already loaded
  if (panel.dataset.loaded === '1') {
    panel.classList.add('open');
    btn.textContent = '▲ Ocultar información';
    return;
  }

  const content = MAS_INFO_DATA[key];
  if (content) {
    panel.innerHTML = content;
    panel.dataset.loaded = '1';
    panel.classList.add('open');
    btn.textContent = '▲ Ocultar información';
  } else {
    panel.innerHTML = `<div class="error-box">⚠️ Contenido no disponible para este subtema.</div>`;
    panel.classList.add('open');
  }
}

// ============================================================
//  TABS
// ============================================================
function switchTab(tab) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + tab).classList.add('active');
  const idx = ['dashboard','teoria','quiz','flashcards','plan','examen'].indexOf(tab);
  document.querySelectorAll('.tab-btn')[idx].classList.add('active');
  currentTab = tab;
  window.scrollTo({top: 0, behavior: 'smooth'});
  if (tab === 'teoria') showTema(currentTeoria);
  if (tab === 'quiz') { qUpdate(); buildAreaBar(); }
  if (tab === 'plan') renderPlan();
  if (tab === 'flashcards') loadFlashcards();
  if (tab === 'examen') renderBreakdown();
  revealElements();
}

function goToArea(tab, area) {
  switchTab(tab);
  if (tab === 'quiz') {
    qGoQuiz(area, null);
  }
}

// ============================================================
//  TEORÍA
// ============================================================
function showTema(n) {
  currentTeoria = n;
  document.getElementById('teoria-content').innerHTML = TEORIA_DATA[n];
  document.querySelectorAll('.teoria-link').forEach((l,i) => {
    l.classList.toggle('active', i === n-1);
  });
  // scroll selected pill into view on mobile
  const active = document.querySelector('.teoria-link.active');
  if (active) active.scrollIntoView({behavior:'smooth', block:'nearest', inline:'center'});
  // scroll content to top
  document.getElementById('teoria-content').scrollTop = 0;
  window.scrollTo({top:0});
}

// ============================================================
//  FLASHCARDS
// ============================================================
function loadFlashcards() {
  const area = parseInt(document.getElementById('fc-area-select').value);
  fcData = FLASHCARDS_DATA[area] || [];
  fcIndex = 0;
  fcFlipped = false;
  document.getElementById('flashcard').classList.remove('flipped');
  updateFlashcard();
}

function updateFlashcard() {
  if (!fcData.length) return;
  document.getElementById('fc-front').textContent = fcData[fcIndex].f;
  document.getElementById('fc-back').textContent = fcData[fcIndex].b;
  document.getElementById('fc-counter').textContent = `${fcIndex+1} / ${fcData.length}`;
  document.getElementById('flashcard').classList.remove('flipped');
  fcFlipped = false;
}

function flipCard() {
  fcFlipped = !fcFlipped;
  document.getElementById('flashcard').classList.toggle('flipped', fcFlipped);
}
function nextCard() { fcIndex = (fcIndex+1) % fcData.length; updateFlashcard(); }
function prevCard() { fcIndex = (fcIndex-1+fcData.length) % fcData.length; updateFlashcard(); }

// ============================================================
//  PLAN
