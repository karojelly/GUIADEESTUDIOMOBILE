function renderPlan() {
  const grid = document.getElementById('plan-grid');
  grid.innerHTML = PLAN.map((d,i) => `
    <div class="day-card ${i===0?'today':''}">
      ${i===0?'<div class="today-badge">🌟 Hoy</div>':''}
      <div class="day-label">Día ${d.day}</div>
      <div class="day-area">${d.area}</div>
      <div class="day-topics">${d.topics}</div>
    </div>
  `).join('');
}

// ============================================================
//  EXAMEN BREAKDOWN
// ============================================================
function renderBreakdown() {
  const el = document.getElementById('full-breakdown');
  el.innerHTML = AREAS.map(a => `
    <div class="area-card" data-area="${a.id}">
      <div class="area-num">Área ${a.id} · ${a.reactivos} reactivos</div>
      <div class="area-name">${a.name}</div>
      ${a.subareas.map(s => `
        <div style="margin-top:0.6rem; font-size:0.78rem; color:var(--accent); font-weight:600; margin-bottom:0.2rem">${s.name}</div>
        <div style="font-size:0.75rem; color:var(--text)">${s.temas.join(' · ')}</div>
      `).join('')}
    </div>
  `).join('');
}

// ============================================================
//  REVEAL ANIMATION
// ============================================================
function revealElements() {
  setTimeout(() => {
    document.querySelectorAll('.reveal').forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), i * 60);
    });
  }, 50);
}

